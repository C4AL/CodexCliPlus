<Window x:Class="CPAD.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{Binding ShellTitle}"
        Height="900"
        Width="1400"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#132033" />
            <Setter Property="BorderBrush" Value="#22324A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="#08111F">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0B1627"
                BorderBrush="#1D2B42"
                BorderThickness="0,0,1,0"
                Padding="24">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="CPAD"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Unified .NET 10 desktop shell with native status panels and embedded WebView2 preview."
                               Foreground="#AFC1D8"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="Service Host"
                                       Foreground="#8BC5FF"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding BackendUrl}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding BackendStatus}"
                                       Foreground="#D7E4F2"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding LastRefreshDisplay}"
                                       Foreground="#7E96B2"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Margin="0,18,0,0"
                            Height="44"
                            Command="{Binding RefreshCommand}"
                            Content="Refresh host snapshot"
                            Background="#4ADE80"
                            Foreground="#08111F"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom">
                    <TextBlock Text="Install Root"
                               Foreground="#8BC5FF"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding InstallRoot}"
                               Foreground="#D7E4F2"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,22,0,0"
                               Text="Repository Layout"
                               Foreground="#8BC5FF"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="apps / src / resources are the active .NET mainline. legacy and reference keep the previous stacks for migration-only lookup."
                               Foreground="#AFC1D8"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Background="#102038">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Unified .NET 10 Mainline"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="The desktop is now a native WPF shell. Runtime state, plugin status, and update status are loaded directly from CPAD.Service."
                                   Foreground="#B9CBE0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="24,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Preview Target"
                                   Foreground="#8BC5FF"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ManagementPreviewUrl}"
                                   Foreground="#D7E4F2"
                                   Width="320"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,18,0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,9,9"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Service State"
                                   Foreground="#8BC5FF"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ServiceSummary}"
                                   Foreground="#E7F0F8"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Margin="9,0,0,9"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Windows Service"
                                   Foreground="#8BC5FF"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding ManagerSummary}"
                                   Foreground="#E7F0F8"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,9,9,0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Codex + CPA Runtime"
                                   Foreground="#8BC5FF"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding CodexSummary}"
                                   Foreground="#E7F0F8"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding CpaSummary}"
                                   Foreground="#9CB4CD"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Margin="9,9,0,0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Plugins + Updates"
                                   Foreground="#8BC5FF"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding PluginSummary}"
                                   Foreground="#E7F0F8"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding UpdateSummary}"
                                   Foreground="#9CB4CD"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}"
                        Background="#102038">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Embedded Management Preview"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="WebView2 is optional here. The primary front-end logic now lives in native WPF."
                                       Foreground="#B9CBE0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Margin="24,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding PreviewStatus}"
                                   Foreground="#8BC5FF"
                                   TextWrapping="Wrap"
                                   Width="320" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        CornerRadius="18"
                        ClipToBounds="True"
                        BorderBrush="#22324A"
                        BorderThickness="1">
                    <wv2:WebView2 x:Name="Browser" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
