using MicaSetup.Design.Commands;
using MicaSetup.Design.ComponentModel;
using MicaSetup.Helper;
using System;
using System.ComponentModel;
using System.Diagnostics;
using System.IO;
using System.Windows;

namespace MicaSetup.ViewModels;

public partial class FinishViewModel : ObservableObject
{
    private const int InstallerDeleteRetryCount = 15;
    private const string InstallerDeleteEnvironmentVariable = "CODEXCLIPLUS_INSTALLER_TO_DELETE";

    private bool installerDeleteScheduled;

    public string Message => Option.Current.MessageOfPage3;

    public bool CleanupInstallerAfterInstall { get; set; } = true;

    public FinishViewModel()
    {
        if (ApplicationDispatcherHelper.MainWindow is Window window)
        {
            window.Closing += OnMainWindowClosing;
        }
    }

    [RelayCommand]
    public void Close()
    {
        if (ApplicationDispatcherHelper.MainWindow is Window window)
        {
            CleanupOriginalInstallerAfterInstall();
            SystemCommands.CloseWindow(window);
        }
    }

    [RelayCommand]
    public void Open()
    {
        if (ApplicationDispatcherHelper.MainWindow is Window window)
        {
            try
            {
                FluentProcess.Create()
                    .FileName(Path.Combine(Option.Current.InstallLocation, Option.Current.ExeName))
                    .WorkingDirectory(Option.Current.InstallLocation)
                    .UseShellExecute()
                    .Start()
                    .Forget();
            }
            catch (Exception e)
            {
                Logger.Error(e);
            }

            CleanupOriginalInstallerAfterInstall();
            SystemCommands.CloseWindow(window);
        }
    }

    private void CleanupOriginalInstallerAfterInstall()
    {
        if (!CleanupInstallerAfterInstall || installerDeleteScheduled)
        {
            return;
        }

        try
        {
            string currentFullPath = GetCurrentExecutablePath();
            if (string.IsNullOrWhiteSpace(currentFullPath) || !File.Exists(currentFullPath))
            {
                Logger.Information($"[InstallerCleanup] current installer missing: {currentFullPath}");
                return;
            }

            if (!string.Equals(Path.GetExtension(currentFullPath), ".exe", StringComparison.OrdinalIgnoreCase))
            {
                Logger.Warning($"[InstallerCleanup] current installer is not an exe: {currentFullPath}");
                return;
            }

            string installedExecutablePath = Path.GetFullPath(Path.Combine(Option.Current.InstallLocation, Option.Current.ExeName));
            if (string.Equals(currentFullPath, installedExecutablePath, StringComparison.OrdinalIgnoreCase))
            {
                Logger.Warning("[InstallerCleanup] current path is the installed application; skip delete.");
                return;
            }

            ScheduleDelayedInstallerDelete(currentFullPath);
            installerDeleteScheduled = true;
            Logger.Information($"[InstallerCleanup] scheduled installer delete: {currentFullPath}");
        }
        catch (Exception e)
        {
            Logger.Error(e);
        }
    }

    private void OnMainWindowClosing(object? sender, CancelEventArgs e)
    {
        CleanupOriginalInstallerAfterInstall();

        if (sender is Window window)
        {
            window.Closing -= OnMainWindowClosing;
        }
    }

    private static string GetCurrentExecutablePath()
    {
        try
        {
            using Process currentProcess = Process.GetCurrentProcess();
            string? processPath = currentProcess.MainModule?.FileName;
            if (!string.IsNullOrWhiteSpace(processPath))
            {
                return Path.GetFullPath(processPath);
            }
        }
        catch (Exception e)
        {
            Logger.Warning($"[InstallerCleanup] cannot resolve process executable path: {e.Message}");
        }

        return Path.GetFullPath(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, AppDomain.CurrentDomain.FriendlyName));
    }

    private static void ScheduleDelayedInstallerDelete(string installerPath)
    {
        string command = BuildInstallerDeleteCommand();
        FluentProcess process = FluentProcess.Create()
            .FileName(GetCommandProcessorPath())
            .Arguments("/d /s /c " + QuoteCmdCommand(command))
            .UseShellExecute(false)
            .CreateNoWindow(true);
        process.StartInfo.EnvironmentVariables[InstallerDeleteEnvironmentVariable] = installerPath;
        process.Start().Forget();
    }

    private static string BuildInstallerDeleteCommand()
    {
        string quotedInstallerPath = QuoteCmdPath("%" + InstallerDeleteEnvironmentVariable + "%");
        return $"for /l %i in (1,1,{InstallerDeleteRetryCount}) do @(del /f /q {quotedInstallerPath} 2>nul & if not exist {quotedInstallerPath} exit /b 0 & if %i geq {InstallerDeleteRetryCount} exit /b 0 & timeout /t 1 /nobreak >nul) & exit /b 0";
    }

    private static string GetCommandProcessorPath()
    {
        string cmdPath = Path.Combine(Environment.SystemDirectory, "cmd.exe");
        return File.Exists(cmdPath) ? cmdPath : "cmd.exe";
    }

    private static string QuoteCmdPath(string value)
    {
        return "\"" + value.Replace("\"", "\"\"") + "\"";
    }

    private static string QuoteCmdCommand(string value)
    {
        return "\"" + value + "\"";
    }
}

partial class FinishViewModel
{
    private RelayCommand? closeCommand;
    public IRelayCommand CloseCommand => closeCommand ??= new RelayCommand(Close);

    private RelayCommand? openCommand;
    public IRelayCommand OpenCommand => openCommand ??= new RelayCommand(Open);
}
