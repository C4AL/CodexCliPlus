<Application x:Class="CPAD.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#F4F6FA" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#17202B" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#526070" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D7DCE5" />
    </Application.Resources>
</Application>
