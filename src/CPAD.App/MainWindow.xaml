<Window x:Class="CPAD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cli Proxy API Desktop"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F6FA">
        <Border Margin="32"
                Padding="28"
                Background="White"
                BorderBrush="#D7DCE5"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#1D2733"
                           Text="Cli Proxy API Desktop" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="#526070"
                           Text="Phase 4 placeholder shell for the native rewrite." />
                <TextBlock Margin="0,24,0,0"
                           FontSize="14"
                           Foreground="#324154"
                           TextWrapping="Wrap"
                           Text="The repository structure, infrastructure layer, and tests are being restored first. The formal native desktop shell will be rebuilt in phase 5 against the audited BetterGI and Management Center references." />
            </StackPanel>
        </Border>
    </Grid>
</Window>
