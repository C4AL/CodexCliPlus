<ui:FluentWindow x:Class="CPAD.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding Title}"
                 Width="1440"
                 Height="920"
                 MinWidth="960"
                 MinHeight="640"
                 FontFamily="{StaticResource TextThemeFontFamily}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Icon="pack://application:,,,/Resources/Icons/ico-transparent.png"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Auto"
                 WindowStartupLocation="CenterScreen"
                 Closing="Window_Closing"
                 Closed="Window_Closed"
                 Loaded="Window_Loaded"
                 mc:Ignorable="d">
    <Grid>
        <wv2:WebView2 x:Name="ManagementWebView"
                      Visibility="Collapsed" />

        <Grid x:Name="LoadingPanel"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="420"
                    Padding="28"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="正在启动桌面管理界面"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="LoadingDescriptionText"
                               Margin="0,10,0,18"
                               Text="正在准备官方 WebUI、本地后端和桌面桥接。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <ProgressBar Height="6"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="BlockerPanel"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="560"
                    MaxWidth="560"
                    Padding="30"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="BlockerTitleText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="桌面宿主无法启动" />
                    <TextBlock x:Name="BlockerDescriptionText"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="请先修复宿主级故障，再继续使用官方管理界面。" />
                    <TextBlock x:Name="BlockerDetailText"
                               Margin="0,18,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Button Width="120"
                                Height="36"
                                Click="RetryButton_Click"
                                Content="重试" />
                        <Button Width="120"
                                Height="36"
                                Margin="12,0,0,0"
                                Click="HideToTrayButton_Click"
                                Content="最小化到托盘" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <tray:NotifyIcon x:Name="TrayIcon"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Resources/Icons/ico-transparent.png"
                         LeftDoubleClick="TrayIcon_LeftDoubleClick"
                         MenuOnRightClick="True"
                         TooltipText="CPAD 桌面版">
            <tray:NotifyIcon.Menu>
                <ContextMenu x:Name="TrayMenu">
                    <MenuItem Header="打开"
                              Click="TrayOpenMenuItem_Click" />
                    <MenuItem Header="重启后端"
                              Click="TrayRestartBackendMenuItem_Click" />
                    <MenuItem Header="检查更新"
                              Click="TrayCheckUpdatesMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出"
                              Click="TrayExitMenuItem_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
