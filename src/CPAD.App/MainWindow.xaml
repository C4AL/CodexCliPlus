<ui:FluentWindow x:Class="CPAD.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding Title}"
                 Width="1440"
                 Height="920"
                 MinWidth="960"
                 MinHeight="640"
                 FontFamily="{StaticResource TextThemeFontFamily}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Auto"
                 WindowStartupLocation="CenterScreen"
                 Closing="Window_Closing"
                 Closed="Window_Closed"
                 Loaded="Window_Loaded"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="46" />
                <ColumnDefinition Width="46" />
            </Grid.ColumnDefinitions>

            <Border x:Name="DragRegion"
                    Grid.Column="0"
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    MouseLeftButtonDown="DragRegion_MouseLeftButtonDown" />

            <Button x:Name="MinimizeWindowButton"
                    Grid.Column="1"
                    Width="46"
                    Height="32"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="MinimizeWindowButton_Click"
                    Content="−"
                    ToolTip="最小化" />
            <Button x:Name="CloseWindowButton"
                    Grid.Column="2"
                    Width="46"
                    Height="32"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="CloseWindowButton_Click"
                    Content="×"
                    ToolTip="关闭" />
        </Grid>

        <wv2:WebView2 x:Name="ManagementWebView"
                      Grid.Row="1"
                      Visibility="Collapsed" />

        <Grid x:Name="LoginPanel"
              Grid.Row="1"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="420"
                    Padding="28"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="登录 CodexCliPlus"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,10,0,18"
                               Text="请输入后端管理密钥以进入桌面管理界面。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="管理密钥"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <PasswordBox x:Name="ManagementKeyPasswordBox"
                                 Height="36"
                                 Margin="0,8,0,0"
                                 KeyDown="ManagementKeyPasswordBox_KeyDown" />
                    <CheckBox x:Name="RememberManagementKeyCheckBox"
                              Margin="0,16,0,0"
                              Content="记住密码" />
                    <TextBlock x:Name="LoginErrorText"
                               Margin="0,12,0,0"
                               FontSize="13"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                    <Button x:Name="LoginButton"
                            Height="38"
                            Margin="0,22,0,0"
                            Click="LoginButton_Click"
                            Content="登录" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="LoadingPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="420"
                    Padding="28"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="正在启动桌面管理界面"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="LoadingDescriptionText"
                               Margin="0,10,0,18"
                               Text="正在准备本地后端和桌面桥接。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <ProgressBar Height="6"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="BlockerPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="560"
                    MaxWidth="560"
                    Padding="30"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="BlockerTitleText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="桌面宿主无法启动" />
                    <TextBlock x:Name="BlockerDescriptionText"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="请先修复宿主级故障，再继续使用管理界面。" />
                    <TextBlock x:Name="BlockerDetailText"
                               Margin="0,18,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Button Width="120"
                                Height="36"
                                Click="RetryButton_Click"
                                Content="重试" />
                        <Button Width="120"
                                Height="36"
                                Margin="12,0,0,0"
                                Click="HideToTrayButton_Click"
                                Content="最小化到托盘" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.RowSpan="2"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                         LeftDoubleClick="TrayIcon_LeftDoubleClick"
                         MenuOnRightClick="True"
                         TooltipText="CodexCliPlus 桌面版">
            <tray:NotifyIcon.Menu>
                <ContextMenu x:Name="TrayMenu">
                    <MenuItem Header="打开"
                              Click="TrayOpenMenuItem_Click" />
                    <MenuItem Header="重启后端"
                              Click="TrayRestartBackendMenuItem_Click" />
                    <MenuItem Header="检查更新"
                              Click="TrayCheckUpdatesMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出"
                              Click="TrayExitMenuItem_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
