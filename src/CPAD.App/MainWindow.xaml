<ui:FluentWindow x:Class="CPAD.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:pages="clr-namespace:CPAD.Views.Pages"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding Title}"
                 Width="1400"
                 Height="900"
                 MinWidth="1180"
                 MinHeight="760"
                 FontFamily="{StaticResource TextThemeFontFamily}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 ExtendsContentIntoTitleBar="True"
                 Icon="pack://application:,,,/Resources/Icons/ico-transparent.png"
                 WindowBackdropType="Auto"
                 WindowStartupLocation="CenterScreen"
                 Closing="Window_Closing"
                 Closed="Window_Closed"
                 Loaded="Window_Loaded"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="ShellTitleBar"
                     Grid.Row="0"
                     Title="{Binding Title}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Icons/ico-transparent.png" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <Border Margin="0,0,10,0"
                            Padding="10,5"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ConnectionDot"
                                     Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock x:Name="HeaderConnectionText"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Style="{StaticResource ShellMutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <ui:Button Width="42"
                               Height="34"
                               Margin="0,0,8,0"
                               Appearance="Transparent"
                               Click="RefreshButton_Click"
                               ToolTip="刷新连接">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowClockwise24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button x:Name="ThemeButton"
                               Width="42"
                               Height="34"
                               Margin="0,0,8,0"
                               Appearance="Transparent"
                               Click="ThemeButton_Click"
                               ToolTip="切换主题">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="WeatherMoon24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button x:Name="BackendActionButton"
                               Appearance="Primary"
                               Content="启动后端"
                               Click="BackendActionButton_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Play24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           Margin="0,0,0,8"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           IsTopSeparatorVisible="False"
                           IsFooterSeparatorVisible="False"
                           OpenPaneLength="236"
                           PaneDisplayMode="LeftFluent"
                           SelectionChanged="RootNavigation_SelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="DashboardNavigationItem"
                                       Tag="dashboard"
                                       Content="仪表盘"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:DashboardPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="config"
                                       Content="配置"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:ConfigPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="ai-providers"
                                       Content="AI 提供商"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:AiProvidersPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE13D;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="auth-files"
                                       Content="认证文件"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:AuthFilesPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B7;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="oauth"
                                       Content="OAuth"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:OAuthPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72E;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="quota"
                                       Content="配额"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:QuotaPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="usage"
                                       Content="用量"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:UsagePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="logs"
                                       Content="日志"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:LogsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D5;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Tag="system"
                                       Content="系统"
                                       NavigationCacheMode="Enabled"
                                       TargetPageType="{x:Type pages:SystemPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9CE;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>

        <Border Grid.Row="2"
                Margin="18,0,18,18"
                Padding="14,10"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="BackendStatusText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Style="{StaticResource ShellMutedTextStyle}" />
                <TextBlock x:Name="ConnectionStatusText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Style="{StaticResource ShellMutedTextStyle}" />
                <TextBlock x:Name="ThemeStatusText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Style="{StaticResource ShellMutedTextStyle}" />
                <TextBlock x:Name="VersionStatusText"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Style="{StaticResource ShellMutedTextStyle}" />
            </Grid>
        </Border>

        <tray:NotifyIcon x:Name="TrayIcon"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Resources/Icons/ico-transparent.png"
                         LeftDoubleClick="TrayIcon_LeftDoubleClick"
                         MenuOnRightClick="True"
                         TooltipText="Cli Proxy API Desktop / CPAD">
            <tray:NotifyIcon.Menu>
                <ContextMenu x:Name="TrayMenu">
                    <ui:MenuItem Header="打开主界面"
                                 Click="TrayOpenMenuItem_Click" />
                    <ui:MenuItem Header="重启后端"
                                 Click="TrayRestartBackendMenuItem_Click" />
                    <ui:MenuItem Header="检查更新"
                                 Click="TrayCheckUpdatesMenuItem_Click" />
                    <Separator />
                    <ui:MenuItem Header="退出并停止后端"
                                 Click="TrayExitMenuItem_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
