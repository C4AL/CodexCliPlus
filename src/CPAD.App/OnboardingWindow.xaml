<Window x:Class="CPAD.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPAD Onboarding"
        Width="720"
        Height="480"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F4F6FA">
        <Border Margin="24"
                Padding="24"
                Background="White"
                BorderBrush="#D7DCE5"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel>
                <TextBlock FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#1D2733"
                           Text="Onboarding Placeholder" />
                <TextBlock Margin="0,12,0,0"
                           FontSize="14"
                           Foreground="#526070"
                           TextWrapping="Wrap"
                           Text="The original onboarding implementation was corrupted and is temporarily replaced to keep phase 4 buildable. A native workflow will be rebuilt in later phases." />
            </StackPanel>
        </Border>
    </Grid>
</Window>
