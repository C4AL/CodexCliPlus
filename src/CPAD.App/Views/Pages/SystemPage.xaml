<Page x:Class="CPAD.Views.Pages.SystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ds="clr-namespace:CPAD.Management.DesignSystem.Controls;assembly=CPAD.Management.DesignSystem"
      Background="{DynamicResource ApplicationBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource ManagementPagePadding}">
            <TextBlock Style="{StaticResource ManagementPageTitleStyle}"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource ManagementPageSubtitleStyle}"
                       Text="{Binding Subtitle}" />

            <StackPanel Margin="0,18,0,0"
                        Orientation="Horizontal">
                <ds:StatusBadge x:Name="StatusBadge" />
                <TextBlock x:Name="ErrorTextBlock"
                           Margin="12,4,0,0"
                           Foreground="{StaticResource ManagementDangerBrush}"
                           Visibility="Collapsed" />
            </StackPanel>

            <ds:FloatingActionBar Margin="0,20,0,0">
                <ds:FloatingActionBar.LeadingContent>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ManagementPrimaryTextBrush}"
                               Text="系统信息" />
                </ds:FloatingActionBar.LeadingContent>
                <ds:FloatingActionBar.TrailingContent>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="RefreshButton_Click"
                                Content="刷新系统" />
                        <Button Click="ToggleRequestLogButton_Click"
                                Content="切换请求日志" />
                    </StackPanel>
                </ds:FloatingActionBar.TrailingContent>
            </ds:FloatingActionBar>

            <Border Style="{StaticResource ManagementCardBorderStyle}"
                    Margin="0,20,0,18">
                <StackPanel>
                    <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                               Text="连接信息" />
                    <ItemsControl x:Name="ConnectionItems"
                                  Margin="0,16,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource ManagementSecondaryTextBrush}"
                                               Text="{Binding Label}" />
                                    <TextBlock Grid.Column="1"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                               Text="{Binding Value}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ManagementCardBorderStyle}"
                    Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                               Text="模型列表" />
                    <ItemsControl x:Name="ModelItems"
                                  Margin="0,16,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12,10"
                                        Background="{StaticResource ManagementSurfaceSubtleBrush}"
                                        CornerRadius="12">
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ManagementCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                               Text="官方链接" />
                    <StackPanel Margin="0,16,0,0"
                                Orientation="Horizontal">
                        <Button Click="OpenCliProxyApiButton_Click"
                                Content="打开 CLIProxyAPI 仓库" />
                        <Button Click="OpenManagementCenterButton_Click"
                                Content="打开 Management Center" />
                        <Button Click="OpenBetterGiButton_Click"
                                Content="打开 BetterGI" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
