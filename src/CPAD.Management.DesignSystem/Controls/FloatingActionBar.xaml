<UserControl x:Class="CPAD.Management.DesignSystem.Controls.FloatingActionBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource ManagementCardBorderStyle}"
            Background="{StaticResource ManagementSurfaceRaisedBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ContentPresenter Content="{Binding LeadingContent, ElementName=Root}"
                              VerticalAlignment="Center" />
            <ContentPresenter Grid.Column="1"
                              Content="{Binding TrailingContent, ElementName=Root}"
                              VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
