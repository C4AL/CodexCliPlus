<UserControl x:Class="CPAD.Management.DesignSystem.Controls.ManagementCodeEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             x:Name="Root">
    <Border BorderBrush="{StaticResource ManagementBorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Background="{StaticResource ManagementSurfaceSubtleBrush}">
        <avalonedit:TextEditor x:Name="Editor"
                               ShowLineNumbers="True"
                               FontFamily="Consolas"
                               FontSize="12"
                               IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
                               TextChanged="Editor_TextChanged" />
    </Border>
</UserControl>
