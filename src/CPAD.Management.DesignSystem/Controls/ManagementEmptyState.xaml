<UserControl x:Class="CPAD.Management.DesignSystem.Controls.ManagementEmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Padding="22"
            Background="{StaticResource ManagementSurfaceSubtleBrush}"
            BorderBrush="{StaticResource ManagementBorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <StackPanel>
            <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                       Text="{Binding Title, ElementName=Root}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource ManagementHintTextStyle}"
                       Text="{Binding Description, ElementName=Root}" />
            <ContentPresenter x:Name="ActionPresenter"
                              Margin="0,18,0,0"
                              Content="{Binding ActionContent, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>
