<UserControl x:Class="CPAD.Management.DesignSystem.Controls.ManagementLogViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CPAD.Management.DesignSystem.Controls"
             x:Name="Root">
    <Grid>
        <Border x:Name="ViewerBorder"
                Background="{StaticResource ManagementSurfaceSubtleBrush}"
                BorderBrush="{StaticResource ManagementBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="14,12,14,10">
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource ManagementHintTextStyle}"
                               Text="只读日志视图" />
                    <Button x:Name="CopyButton"
                            DockPanel.Dock="Right"
                            Padding="12,6"
                            Click="CopyButton_Click"
                            Content="{Binding CopyButtonText, ElementName=Root}" />
                </DockPanel>

                <TextBox x:Name="ViewerTextBox"
                         Grid.Row="1"
                         Margin="14,0,14,14"
                         Padding="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         Text="{Binding Text, ElementName=Root}" />
            </Grid>
        </Border>

        <controls:ManagementEmptyState x:Name="EmptyStateControl"
                                       Title="{Binding EmptyTitle, ElementName=Root}"
                                       Description="{Binding EmptyDescription, ElementName=Root}" />
    </Grid>
</UserControl>
