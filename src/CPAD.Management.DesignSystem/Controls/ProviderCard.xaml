<UserControl x:Class="CPAD.Management.DesignSystem.Controls.ProviderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Button x:Name="CardButton"
            Click="CardButton_Click"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch">
        <Border Padding="16"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ManagementPrimaryTextBrush}"
                               Text="{Binding Title, ElementName=Root}" />
                    <Border Grid.Column="1"
                            Padding="8,3"
                            Background="{StaticResource ManagementSurfaceSubtleBrush}"
                            CornerRadius="999">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ManagementSecondaryTextBrush}"
                                   Text="{Binding BadgeText, ElementName=Root}" />
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Style="{StaticResource ManagementHintTextStyle}"
                           Text="{Binding Subtitle, ElementName=Root}" />

                <TextBlock Grid.Row="2"
                           Margin="0,12,0,0"
                           FontSize="12"
                           Foreground="{StaticResource ManagementAccentStrongBrush}"
                           Text="{Binding MetaText, ElementName=Root}" />
            </Grid>
        </Border>
    </Button>
</UserControl>
