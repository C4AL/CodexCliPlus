<Application
  x:Class="CodexCliPlus.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Light" />
        <ui:ControlsDictionary />
        <vio:ControlsDictionary />
        <ResourceDictionary Source="/Views/Controls/WpfUi/FaFontIconStyle.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <FontFamily x:Key="TextThemeFontFamily"
        >/Resources/Fonts/MiSans-Regular.ttf#MiSans</FontFamily
      >
      <FontFamily x:Key="FgiIconFontFamily">/Resources/Fonts/Fgi-Regular.ttf#FgiRegular</FontFamily>

      <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F6F6F6" />
      <SolidColorBrush x:Key="AccentBrush" Color="#8B8680" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="#EFEDEA" />
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="#2D2A26" />
      <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6D6760" />
      <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5" />

      <Thickness x:Key="ShellPageMargin">28,22,28,18</Thickness>

      <Style x:Key="ShellHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TextThemeFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      </Style>

      <Style x:Key="ShellMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TextThemeFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
