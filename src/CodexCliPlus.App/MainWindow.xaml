                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                      x:Name="SettingsCheckUpdateButton"
                      Width="112"
                      Height="34"
                      HorizontalAlignment="Left"
                      Click="SettingsCheckUpdateButton_Click"
                      AutomationProperties.AutomationId="SettingsCheckUpdateButton"
                      Content="检查更新"
                    />
                    <Button
                      x:Name="SettingsApplyUpdateButton"
                      Grid.Column="1"
                      Width="112"
                      Height="34"
                      Margin="8,0,0,0"
                      HorizontalAlignment="Left"
                      Click="SettingsApplyUpdateButton_Click"
                      AutomationProperties.AutomationId="SettingsApplyUpdateButton"
                      Content="下载并应用"
                      IsEnabled="False"
                    />
                    <ProgressBar
                      x:Name="SettingsUpdateProgressBar"
                      Grid.Column="2"
                      Height="4"
                      Margin="16,15,0,0"
                      Minimum="0"
                      Maximum="100"
                      Value="0"
                      Visibility="Collapsed"
                    />
                  </Grid>
                </StackPanel>
              </Border>

              <Border
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
              >
                <StackPanel>
                  <TextBlock
                    Text="统计"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                  />
                  <TextBlock
                    Text="清除本地持久化的使用统计，并向后端导入空快照。"
                    Margin="0,10,0,12"
                    FontSize="13"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    TextWrapping="Wrap"
                  />
                  <Button
                    x:Name="SettingsClearUsageButton"
                    Width="128"
                    Height="34"
                    HorizontalAlignment="Left"
                    Click="SettingsClearUsageButton_Click"
                    AutomationProperties.AutomationId="SettingsClearUsageButton"
                    Content="清除统计"
                  />
                </StackPanel>
              </Border>

              <Border
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
              >
                <StackPanel>
                  <TextBlock
                    Text="主题"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                  />
                  <CheckBox
                    x:Name="SettingsFollowSystemCheckBox"
                    Margin="0,12,0,0"
                    VerticalAlignment="Center"
                    Checked="SettingsFollowSystemCheckBox_Changed"
                    Unchecked="SettingsFollowSystemCheckBox_Changed"
                    AutomationProperties.AutomationId="SettingsFollowSystemCheckBox"
                    Content="跟随系统主题"
                  />
                </StackPanel>
              </Border>

              <Border
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
              >
                <StackPanel>
                  <TextBlock
                    Text="模型概览"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                  />
                  <TextBlock
                    x:Name="SettingsModelOverviewText"
                    Margin="0,10,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    TextWrapping="Wrap"
                  />
                  <TextBlock
                    x:Name="SettingsProviderOverviewText"
                    Margin="0,6,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    TextWrapping="Wrap"
                  />
                </StackPanel>
              </Border>

              <Grid Margin="0,16,0,0">
                <Border
                  Padding="16"
                  CornerRadius="10"
                  Background="{DynamicResource SurfaceAltBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                >
                  <StackPanel>
                    <TextBlock
                      Text="注销账号"
                      FontSize="14"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                    />
                    <TextBlock
                      Text="注销本机保存的登录状态，不会更改后端配置。"
                      Margin="0,10,0,12"
                      FontSize="13"
                      Foreground="{DynamicResource SecondaryTextBrush}"
                      TextWrapping="Wrap"
                    />
                    <Button
                      x:Name="SettingsClearLoginButton"
                      Width="128"
                      Height="34"
                      HorizontalAlignment="Left"
                      Click="SettingsClearLoginButton_Click"
                      AutomationProperties.AutomationId="SettingsClearLoginButton"
                      Content="注销账号"
                    />
                  </StackPanel>
                </Border>
              </Grid>

              <Border
                Margin="0,16,0,0"
                Padding="16"
                CornerRadius="10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
              >
                <StackPanel>
                  <TextBlock
                    Text="快捷链接"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                  />
                  <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <Button Height="34" Padding="12,0" Click="SettingsOpenMainRepoButton_Click">
                      <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide
                          Kind="Github"
                          Width="15"
                          Height="15"
                          VerticalAlignment="Center"
                        />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="主程序仓库" />
                      </StackPanel>
                    </Button>
                    <Button
                      Height="34"
                      Margin="8,0,0,0"
                      Padding="12,0"
                      Click="SettingsOpenWebUiRepoButton_Click"
                    >
                      <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide
                          Kind="Github"
                          Width="15"
                          Height="15"
                          VerticalAlignment="Center"
                        />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="前端仓库" />
                      </StackPanel>
                    </Button>
                    <Button
                      Height="34"
                      Margin="8,0,0,0"
                      Padding="12,0"
                      Click="SettingsOpenDocsButton_Click"
                    >
                      <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide
                          Kind="BookOpen"
                          Width="15"
                          Height="15"
                          VerticalAlignment="Center"
                        />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="使用教程" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <tray:NotifyIcon
      x:Name="TrayIcon"
      Grid.RowSpan="2"
      FocusOnLeftClick="False"
      Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
      LeftDoubleClick="TrayIcon_LeftDoubleClick"
      MenuOnRightClick="True"
      TooltipText="CodexCliPlus 桌面版"
    >
      <tray:NotifyIcon.Menu>
        <ContextMenu x:Name="TrayMenu">
          <MenuItem Header="打开" Click="TrayOpenMenuItem_Click" />
          <MenuItem Header="重启后端" Click="TrayRestartBackendMenuItem_Click" />
          <MenuItem Header="检查更新" Click="TrayCheckUpdatesMenuItem_Click" />
          <Separator />
          <MenuItem Header="退出" Click="TrayExitMenuItem_Click" />
        </ContextMenu>
      </tray:NotifyIcon.Menu>
    </tray:NotifyIcon>
  </Grid>
</ui:FluentWindow>
