<ui:FluentWindow
  x:Class="CodexCliPlus.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
  Title="{Binding Title}"
  Width="1440"
  Height="920"
  MinWidth="960"
  MinHeight="640"
  FontFamily="{StaticResource TextThemeFontFamily}"
  Background="{DynamicResource ApplicationBackgroundBrush}"
  Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="Auto"
  WindowStartupLocation="CenterScreen"
  UseLayoutRounding="True"
  SnapsToDevicePixels="True"
  Closing="Window_Closing"
  Closed="Window_Closed"
  Activated="Window_Activated"
  Deactivated="Window_Deactivated"
  Loaded="Window_Loaded"
  LocationChanged="Window_PlacementChanged"
  SizeChanged="Window_PlacementChanged"
  StateChanged="Window_PlacementChanged"
  mc:Ignorable="d"
>
  <ui:FluentWindow.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/Resources/ShellResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="50" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="46" />
        <ColumnDefinition Width="46" />
      </Grid.ColumnDefinitions>

      <Border
        x:Name="DragRegion"
        Grid.ColumnSpan="4"
        Background="{DynamicResource SurfaceBrush}"
        MouseLeftButtonDown="DragRegion_MouseLeftButtonDown"
      />

      <Button
        x:Name="ShellSidebarButton"
        Grid.Column="0"
        Style="{StaticResource ShellIconButtonStyle}"
        Visibility="Collapsed"
        AutomationProperties.AutomationId="ShellSidebarButton"
        AutomationProperties.Name="切换侧栏"
        Click="ShellSidebarButton_Click"
        ToolTip="切换侧栏"
        Panel.ZIndex="1"
      >
        <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
          <Canvas Width="24" Height="24">
            <Path
              Data="M4,6 L20,6 M4,12 L20,12 M4,18 L20,18"
              Fill="Transparent"
              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
              StrokeThickness="1.8"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
            />
          </Canvas>
        </Viewbox>
      </Button>

      <Button
        x:Name="ShellBrandDockButton"
        Grid.Column="1"
        Margin="4,0,18,0"
        Style="{StaticResource ShellBrandDockButtonStyle}"
        AutomationProperties.AutomationId="ShellBrandDockButton"
        AutomationProperties.Name="打开状态面板"
        Click="ShellBrandDockButton_Click"
        ToolTip="打开状态面板"
        Panel.ZIndex="1"
      >
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Grid Width="34" Height="34" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border Background="{DynamicResource AccentSoftBrush}" CornerRadius="9" />
            <Image
              Width="28"
              Height="28"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderOptions.BitmapScalingMode="HighQuality"
              SnapsToDevicePixels="True"
              Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png"
            />
            <Ellipse
              x:Name="ShellBrandStatusDot"
              Width="12"
              Height="12"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Fill="{DynamicResource AccentBrush}"
              Stroke="{DynamicResource SurfaceBrush}"
              StrokeThickness="1.4"
            >
              <Ellipse.Effect>
                <DropShadowEffect
                  x:Name="ShellBrandStatusDotGlow"
                  BlurRadius="8"
                  Direction="0"
                  Color="#6614B8A6"
                  Opacity="1"
                  ShadowDepth="0"
                />
              </Ellipse.Effect>
            </Ellipse>
          </Grid>
          <Grid
            Width="112"
            Height="24"
            Margin="10,0,0,0"
            VerticalAlignment="Center"
            ClipToBounds="True"
          >
            <TextBlock
              Text="CodexCliPlus"
              FontSize="15"
              FontWeight="SemiBold"
              Foreground="{DynamicResource PrimaryTextBrush}"
              VerticalAlignment="Top"
            />
            <Grid
              Width="90"
              Height="3"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              ClipToBounds="True"
            >
              <Rectangle
                Height="1"
                Margin="0,0,0,1"
                VerticalAlignment="Bottom"
                Fill="{DynamicResource AccentBrush}"
                Opacity="0.16"
                RadiusX="1"
                RadiusY="1"
              />
              <Rectangle
                Width="30"
                Height="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Fill="{DynamicResource AccentBrush}"
                Opacity="0.7"
                RadiusX="1"
                RadiusY="1"
              >
                <Rectangle.RenderTransform>
                  <TranslateTransform X="-34" />
                </Rectangle.RenderTransform>
                <Rectangle.Triggers>
                  <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                      <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation
                          Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                          From="-34"
                          To="94"
                          Duration="0:0:2.6"
                        >
                          <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                          </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                      </Storyboard>
                    </BeginStoryboard>
                  </EventTrigger>
                </Rectangle.Triggers>
              </Rectangle>
            </Grid>
          </Grid>
        </StackPanel>
      </Button>

      <Popup
        x:Name="ShellBrandDockPopup"
        PlacementTarget="{Binding ElementName=ShellBrandDockButton}"
        Placement="Bottom"
        VerticalOffset="8"
        StaysOpen="True"
        AllowsTransparency="True"
        PopupAnimation="None"
        Opened="ShellBrandDockPopup_Opened"
        Closed="ShellBrandDockPopup_Closed"
        AutomationProperties.AutomationId="ShellBrandDockPopup"
      >
        <Border
          x:Name="ShellBrandDockCard"
          Width="336"
          Padding="16"
          Background="{DynamicResource ShellDockGlassBrush}"
          BorderBrush="{DynamicResource ShellDockGlassBorderBrush}"
          BorderThickness="1"
          CornerRadius="18"
          Effect="{x:Null}"
          Opacity="0"
          RenderTransformOrigin="0.5,0"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True"
        >
          <Border.RenderTransform>
            <TransformGroup>
              <ScaleTransform x:Name="ShellBrandDockScaleTransform" ScaleX="1" ScaleY="0.88" />
              <TranslateTransform x:Name="ShellBrandDockTranslateTransform" Y="-8" />
            </TransformGroup>
          </Border.RenderTransform>
          <Grid>
            <Border
              Margin="-15"
              Background="{StaticResource ShellGlassSweepBrush}"
              CornerRadius="18"
              IsHitTestVisible="False"
              Opacity="0.5"
            />
            <Border
              Margin="-1"
              BorderBrush="{DynamicResource ShellDockGlassHighlightBrush}"
              BorderThickness="1,1,1,0"
              CornerRadius="18"
              IsHitTestVisible="False"
              Opacity="0.78"
            />
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Text="程序版本"
                FontSize="12"
                Foreground="{DynamicResource SecondaryTextBrush}"
              />
              <TextBlock
                x:Name="ShellDockAppVersionText"
                Grid.Row="0"
                Grid.Column="1"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryTextBrush}"
                TextTrimming="CharacterEllipsis"
                AutomationProperties.AutomationId="ShellDockAppVersionText"
              />

              <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,10,0,0"
                Text="内核版本"
                FontSize="12"
                Foreground="{DynamicResource SecondaryTextBrush}"
              />
              <TextBlock
                x:Name="ShellDockCoreVersionText"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,10,0,0"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryTextBrush}"
                TextTrimming="CharacterEllipsis"
                AutomationProperties.AutomationId="ShellDockCoreVersionText"
              />

              <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,10,0,0"
                Text="连接状态"
                FontSize="12"
                Foreground="{DynamicResource SecondaryTextBrush}"
              />
              <StackPanel
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,10,0,0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
              >
                <Ellipse
                  x:Name="ShellDockConnectionStatusDot"
                  Width="8"
                  Height="8"
                  Margin="0,0,7,0"
                  Fill="{DynamicResource SecondaryTextBrush}"
                />
                <TextBlock
                  x:Name="ShellDockConnectionStatusText"
                  FontSize="12"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  AutomationProperties.AutomationId="ShellDockConnectionStatusText"
                />
              </StackPanel>

              <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                Margin="0,10,0,0"
                Text="后端地址"
                FontSize="12"
                Foreground="{DynamicResource SecondaryTextBrush}"
              />
              <Grid Grid.Row="3" Grid.Column="1" Margin="0,7,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  x:Name="ShellDockBackendAddressText"
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  FontFamily="Consolas"
                  FontSize="12"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  TextTrimming="CharacterEllipsis"
                  AutomationProperties.AutomationId="ShellDockBackendAddressText"
                />
                <Button
                  x:Name="ShellDockCopyBackendAddressButton"
                  Grid.Column="1"
                  Style="{StaticResource ShellInlineIconButtonStyle}"
                  Width="26"
                  Height="26"
                  HorizontalAlignment="Right"
                  Click="ShellDockCopyBackendAddressButton_Click"
                  AutomationProperties.AutomationId="ShellDockCopyBackendAddressButton"
                  AutomationProperties.Name="复制后端地址"
                  ToolTip="复制后端地址"
                >
                  <iconPacks:PackIconLucide
                    Kind="Copy"
                    Width="15"
                    Height="15"
                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                  />
                </Button>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Popup>

      <StackPanel
        Grid.Column="3"
        Margin="0,0,6,0"
        Orientation="Horizontal"
        VerticalAlignment="Center"
        Panel.ZIndex="1"
      >
        <Button
          x:Name="ShellThemeButton"
          Style="{StaticResource ShellTopActionButtonStyle}"
          AutomationProperties.AutomationId="ShellThemeButton"
          AutomationProperties.Name="切换主题"
          Click="ShellThemeButton_Click"
          ToolTip="切换主题"
        >
          <iconPacks:PackIconLucide
            Kind="SunMoon"
            Width="17"
            Height="17"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            SnapsToDevicePixels="True"
            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
          >
            <iconPacks:PackIconLucide.RenderTransform>
              <TranslateTransform Y="-1" />
            </iconPacks:PackIconLucide.RenderTransform>
          </iconPacks:PackIconLucide>
        </Button>
        <Button
          x:Name="ShellSettingsButton"
          Margin="6,0,0,0"
          Style="{StaticResource ShellTopActionButtonStyle}"
          AutomationProperties.AutomationId="ShellSettingsButton"
          AutomationProperties.Name="设置"
          Click="ShellSettingsButton_Click"
          ToolTip="设置"
        >
          <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
            <Canvas Width="24" Height="24">
              <Path
                Data="M12,8.5 A3.5,3.5 0 1 0 12,15.5 A3.5,3.5 0 1 0 12,8.5 M19,13.5 L21,15 L19,18.5 L16.6,17.7 C16,18.1 15.4,18.5 14.7,18.8 L14.3,21 L9.7,21 L9.3,18.8 C8.6,18.5 8,18.1 7.4,17.7 L5,18.5 L3,15 L5,13.5 C4.9,13 4.8,12.5 4.8,12 C4.8,11.5 4.9,11 5,10.5 L3,9 L5,5.5 L7.4,6.3 C8,5.9 8.6,5.5 9.3,5.2 L9.7,3 L14.3,3 L14.7,5.2 C15.4,5.5 16,5.9 16.6,6.3 L19,5.5 L21,9 L19,10.5 C19.1,11 19.2,11.5 19.2,12 C19.2,12.5 19.1,13 19,13.5 Z"
                Fill="Transparent"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                StrokeThickness="1.45"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
              />
            </Canvas>
          </Viewbox>
        </Button>
      </StackPanel>

      <Button
        x:Name="MinimizeWindowButton"
        Grid.Column="4"
        Width="46"
        Height="50"
        Padding="0"
        Style="{StaticResource TitleBarButtonStyle}"
        Click="MinimizeWindowButton_Click"
        Content="−"
        ToolTip="最小化"
      />
      <Button
        x:Name="CloseWindowButton"
        Grid.Column="5"
        Width="46"
        Height="50"
        Padding="0"
        Style="{StaticResource TitleBarButtonStyle}"
        Click="CloseWindowButton_Click"
        Content="×"
        ToolTip="关闭"
      />
    </Grid>

    <Grid x:Name="ManagementContentHost" Grid.Row="1" ClipToBounds="False">
      <wv2:WebView2
        x:Name="ManagementWebView"
        Panel.ZIndex="0"
        AutomationProperties.AutomationId="ManagementWebView"
        Visibility="Collapsed"
      />

      <Popup
        x:Name="ShellNavigationDockPopup"
        PlacementTarget="{Binding ElementName=ManagementContentHost}"
        Placement="Relative"
        HorizontalOffset="0"
        VerticalOffset="0"
        AllowsTransparency="True"
        StaysOpen="True"
        PopupAnimation="None"
      >
        <Border
          x:Name="ShellNavigationDockHost"
          Width="56"
          Height="{Binding ActualHeight, ElementName=ManagementContentHost}"
          HorizontalAlignment="Left"
          VerticalAlignment="Stretch"
          ClipToBounds="False"
          Background="Transparent"
          MouseEnter="ShellNavigationDockHost_MouseEnter"
          MouseMove="ShellNavigationDockHost_MouseMove"
          MouseLeave="ShellNavigationDockHost_MouseLeave"
          Panel.ZIndex="2"
          AutomationProperties.AutomationId="ShellNavigationDockHost"
        >
          <Grid Width="270" HorizontalAlignment="Left" ClipToBounds="False">
            <Border
              x:Name="ShellNavigationRailTrack"
              Width="18"
              Height="136"
              Margin="14,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Background="{StaticResource NavigationDockRailTrackHighlightBrush}"
              CornerRadius="9"
              Opacity="0.78"
            />
            <Border
              x:Name="ShellNavigationRail"
              Width="7"
              Height="108"
              Margin="19,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Background="{DynamicResource NavigationDockRailBrush}"
              CornerRadius="4"
              Opacity="0.95"
            />
            <Border
              x:Name="ShellNavigationPanel"
              Width="58"
              Height="132"
              Margin="34,18,12,18"
              Padding="0,10"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Background="{DynamicResource NavigationDockPanelBrush}"
              BorderBrush="{DynamicResource NavigationDockBorderBrush}"
              BorderThickness="1"
              CornerRadius="24"
              ClipToBounds="True"
              IsHitTestVisible="False"
              Opacity="0"
              MouseEnter="ShellNavigationPanel_MouseEnter"
              MouseLeave="ShellNavigationPanel_MouseLeave"
              Effect="{x:Null}"
            >
              <Border.RenderTransform>
                <TranslateTransform X="-8" />
              </Border.RenderTransform>
              <Grid ClipToBounds="True">
                <Border
                  Background="{StaticResource ShellGlassSweepBrush}"
                  IsHitTestVisible="False"
                  Opacity="0.38"
                />
                <Border
                  Margin="0"
                  BorderBrush="{DynamicResource NavigationDockInnerHighlightBrush}"
                  BorderThickness="1,1,1,0"
                  CornerRadius="23"
                  IsHitTestVisible="False"
                  Opacity="0.72"
                />
                <StackPanel x:Name="ShellNavigationItemsHost" VerticalAlignment="Center">
                  <Button
                    x:Name="ShellNavDashboardButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="LayoutDashboard"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="仪表盘" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavDashboardOverviewButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/dashboard/overview"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="Terminal"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="运行概览" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavConfigButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/config"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="Settings"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="配置" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavAccountButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/ai-providers"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="CircleUserRound"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="账号配置" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavAuthFilesButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/auth-files"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="FileKey"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="认证文件" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavQuotaButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/quota"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="CircleGauge"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="额度" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavUsageButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/usage"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="ChartNoAxesCombined"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="用量" />
                    </StackPanel>
                  </Button>
                  <Button
                    x:Name="ShellNavLogsButton"
                    Style="{StaticResource ShellNavigationButtonStyle}"
                    Click="ShellNavigationButton_Click"
                    CommandParameter="/logs"
                  >
                    <StackPanel Orientation="Horizontal">
                      <iconPacks:PackIconLucide
                        Kind="FileText"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                      />
                      <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Text="日志查看" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Popup>
    </Grid>

    <Grid
      x:Name="UpgradeNoticePanel"
      Grid.Row="1"
      Visibility="Collapsed"
      Background="{DynamicResource ApplicationBackgroundBrush}"
    >
      <Border
        Width="500"
        Padding="30"
        Style="{StaticResource ShellRaisedPanelStyle}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
      >
        <StackPanel>
          <TextBlock
            Text="CodexCliPlus 已更新"
            FontSize="26"
            FontWeight="SemiBold"
            Foreground="{DynamicResource PrimaryTextBrush}"
          />
          <TextBlock
            x:Name="UpgradeNoticeVersionText"
            Margin="0,12,0,0"
            FontSize="15"
            Foreground="{DynamicResource PrimaryTextBrush}"
            TextWrapping="Wrap"
          />
          <TextBlock
            Margin="0,10,0,0"
            Text="更新不会更改你的安全密钥、后端配置和账号文件。"
            FontSize="13"
            Foreground="{DynamicResource SecondaryTextBrush}"
            TextWrapping="Wrap"
          />
          <Button
            x:Name="UpgradeContinueButton"
            Width="120"
            Height="38"
            Margin="0,24,0,0"
            HorizontalAlignment="Left"
            Click="UpgradeContinueButton_Click"
            Content="继续"
          />
        </StackPanel>
      </Border>
    </Grid>

    <Grid
      x:Name="FirstRunKeyPanel"
      Grid.Row="1"
      Visibility="Collapsed"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      AutomationProperties.AutomationId="FirstRunKeyPanel"
    >
      <Grid>
        <Border
          Width="760"
          Padding="0"
          Style="{StaticResource ShellRaisedPanelStyle}"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
        >
          <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Padding="30,28,30,22" Background="{DynamicResource SurfaceAltBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock
                    Text="首次初始化安全密钥"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                  />
                  <TextBlock
                    Margin="0,10,0,0"
                    Text="请立即保存下面的安全密钥。完整内容只会在本页显示一次。"
                    FontSize="13"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    TextWrapping="Wrap"
                  />
                </StackPanel>
                <Border
                  Grid.Column="1"
                  Width="48"
                  Height="48"
                  CornerRadius="14"
                  Background="{DynamicResource AccentSoftBrush}"
                  BorderBrush="{DynamicResource AccentBrush}"
                  BorderThickness="1"
                >
