<ui:FluentWindow x:Class="CodexCliPlus.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding Title}"
                 Width="1440"
                 Height="920"
                 MinWidth="960"
                 MinHeight="640"
                 FontFamily="{StaticResource TextThemeFontFamily}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Auto"
                 WindowStartupLocation="CenterScreen"
                 UseLayoutRounding="True"
                 SnapsToDevicePixels="True"
                 Closing="Window_Closing"
                 Closed="Window_Closed"
                 Loaded="Window_Loaded"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <DropShadowEffect x:Key="ShellRaisedPanelShadow"
                          BlurRadius="16"
                          Direction="270"
                          Color="#10000000"
                          Opacity="1"
                          ShadowDepth="2" />
        <Style x:Key="ShellRaisedPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Effect" Value="{StaticResource ShellRaisedPanelShadow}" />
        </Style>
        <Style x:Key="ShellIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1"
                                    ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96"
                                                        ScaleY="0.96" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShellInlineIconButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource ShellIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Opacity" Value="0.58" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShellIconViewboxStyle" TargetType="{x:Type Viewbox}">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
        <Style x:Key="ShellTextToolTipStyle" TargetType="{x:Type ToolTip}">
            <Setter Property="FontFamily" Value="{StaticResource TextThemeFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style x:Key="ShellStatusPillStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,16,0,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="46" />
                <ColumnDefinition Width="46" />
            </Grid.ColumnDefinitions>

            <Border x:Name="DragRegion"
                    Grid.ColumnSpan="4"
                    Background="{DynamicResource SurfaceBrush}"
                    MouseLeftButtonDown="DragRegion_MouseLeftButtonDown" />

            <Button x:Name="ShellSidebarButton"
                    Grid.Column="0"
                    Style="{StaticResource ShellIconButtonStyle}"
                    AutomationProperties.AutomationId="ShellSidebarButton"
                    AutomationProperties.Name="切换侧栏"
                    Click="ShellSidebarButton_Click"
                    ToolTip="切换侧栏"
                    Panel.ZIndex="1">
                <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                    <Canvas Width="24"
                            Height="24">
                        <Path Data="M4,6 L20,6 M4,12 L20,12 M4,18 L20,18"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Viewbox>
            </Button>

            <StackPanel Grid.Column="1"
                        Margin="4,0,18,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Panel.ZIndex="1">
                <Grid Width="34"
                      Height="34"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Border Background="{DynamicResource AccentSoftBrush}"
                            CornerRadius="9" />
                    <Image Width="28"
                           Height="28"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png" />
                    <Ellipse x:Name="ShellBrandStatusDot"
                             Width="7"
                             Height="7"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Fill="{DynamicResource AccentBrush}"
                             Stroke="{DynamicResource SurfaceBrush}"
                             StrokeThickness="1" />
                </Grid>
                <Grid Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="CodexCliPlus"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="桌面宿主"
                                   Margin="0,1,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                    <Rectangle Height="1"
                               Width="72"
                               VerticalAlignment="Bottom"
                               Fill="{DynamicResource AccentBrush}"
                               Opacity="0.34">
                        <Rectangle.RenderTransform>
                            <TranslateTransform X="-72" />
                        </Rectangle.RenderTransform>
                        <Rectangle.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="-72"
                                                         To="110"
                                                         Duration="0:0:3.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Rectangle.Triggers>
                    </Rectangle>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1">
                <Border Style="{StaticResource ShellStatusPillStyle}"
                        AutomationProperties.AutomationId="ShellConnectionStatusPill">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="ShellConnectionStatusDot"
                                 Width="7"
                                 Height="7"
                                 Margin="0,0,7,0"
                                 Fill="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="ShellConnectionStatusText"
                                   Text="未连接"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0"
                        MaxWidth="280"
                        Style="{StaticResource ShellStatusPillStyle}">
                    <TextBlock x:Name="ShellBackendAddressText"
                               Text="-"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Margin="0,0,6,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Panel.ZIndex="1">
                <Button x:Name="ShellRefreshButton"
                        Style="{StaticResource ShellIconButtonStyle}"
                        AutomationProperties.AutomationId="ShellRefreshButton"
                        AutomationProperties.Name="刷新"
                        Click="ShellRefreshButton_Click"
                        ToolTip="刷新">
                    <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                        <Canvas Width="24"
                                Height="24">
                            <Path Data="M20,12 C20,16.418 16.418,20 12,20 C7.582,20 4,16.418 4,12 C4,7.582 7.582,4 12,4 C14.245,4 16.277,4.924 17.73,6.414 M20,5 L20,10 L15,10"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="ShellThemeButton"
                        Margin="6,0,0,0"
                        Style="{StaticResource ShellIconButtonStyle}"
                        AutomationProperties.AutomationId="ShellThemeButton"
                        AutomationProperties.Name="切换主题"
                        Click="ShellThemeButton_Click"
                        ToolTip="切换主题">
                    <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                        <Canvas Width="24"
                                Height="24">
                            <Path Data="M12,3 C7.029,3 3,7.029 3,12 C3,16.971 7.029,21 12,21 C12,21 12,3 12,3 Z M12,3 C16.971,3 21,7.029 21,12 C21,16.971 16.971,21 12,21"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="ShellSettingsButton"
                        Margin="6,0,0,0"
                        Style="{StaticResource ShellIconButtonStyle}"
                        AutomationProperties.AutomationId="ShellSettingsButton"
                        AutomationProperties.Name="设置"
                        Click="ShellSettingsButton_Click"
                        ToolTip="设置">
                    <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                        <Canvas Width="24"
                                Height="24">
                            <Path Data="M12,8.5 A3.5,3.5 0 1 0 12,15.5 A3.5,3.5 0 1 0 12,8.5 M19,13.5 L21,15 L19,18.5 L16.6,17.7 C16,18.1 15.4,18.5 14.7,18.8 L14.3,21 L9.7,21 L9.3,18.8 C8.6,18.5 8,18.1 7.4,17.7 L5,18.5 L3,15 L5,13.5 C4.9,13 4.8,12.5 4.8,12 C4.8,11.5 4.9,11 5,10.5 L3,9 L5,5.5 L7.4,6.3 C8,5.9 8.6,5.5 9.3,5.2 L9.7,3 L14.3,3 L14.7,5.2 C15.4,5.5 16,5.9 16.6,6.3 L19,5.5 L21,9 L19,10.5 C19.1,11 19.2,11.5 19.2,12 C19.2,12.5 19.1,13 19,13.5 Z"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  StrokeThickness="1.45"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>

            <Button x:Name="MinimizeWindowButton"
                    Grid.Column="4"
                    Width="46"
                    Height="56"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="MinimizeWindowButton_Click"
                    Content="−"
                    ToolTip="最小化" />
            <Button x:Name="CloseWindowButton"
                    Grid.Column="5"
                    Width="46"
                    Height="56"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="CloseWindowButton_Click"
                    Content="×"
                    ToolTip="关闭" />
        </Grid>

        <wv2:WebView2 x:Name="ManagementWebView"
                      Grid.Row="1"
                      AutomationProperties.AutomationId="ManagementWebView"
                      Visibility="Collapsed" />

        <Grid x:Name="UpgradeNoticePanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="500"
                    Padding="30"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="CodexCliPlus 已更新"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="UpgradeNoticeVersionText"
                               Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Text="更新不会更改你的安全密钥、后端配置和账号文件。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <Button x:Name="UpgradeContinueButton"
                            Width="120"
                            Height="38"
                            Margin="0,24,0,0"
                            HorizontalAlignment="Left"
                            Click="UpgradeContinueButton_Click"
                            Content="继续" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="FirstRunKeyPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              AutomationProperties.AutomationId="FirstRunKeyPanel">
            <Grid>
                <Border Width="620"
                        Padding="30"
                        Style="{StaticResource ShellRaisedPanelStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="首次初始化安全密钥"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Margin="0,10,0,18"
                                       Text="请立即保存下面的安全密钥。完整内容只会在本页显示一次。"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="安全密钥"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0"
                                      Width="360"
                                      Height="40"
                                      HorizontalAlignment="Left">
                                    <TextBox x:Name="FirstRunSecurityKeyTextBox"
                                             Height="40"
                                             Width="360"
                                             Padding="10,8,48,8"
                                             HorizontalAlignment="Left"
                                             FontFamily="Consolas"
                                             FontSize="15"
                                             HorizontalScrollBarVisibility="Hidden"
                                             IsReadOnly="True"
                                             AutomationProperties.AutomationId="FirstRunSecurityKeyTextBox"
                                             TextWrapping="NoWrap"
                                             VerticalContentAlignment="Center"
                                             VerticalScrollBarVisibility="Disabled" />
                                    <Button x:Name="FirstRunCopyKeyButton"
                                            Style="{StaticResource ShellInlineIconButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,5,0"
                                            Click="FirstRunCopyKeyButton_Click"
                                            AutomationProperties.AutomationId="FirstRunCopyKeyButton"
                                            AutomationProperties.Name="复制密钥">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource ShellTextToolTipStyle}"
                                                     Content="复制密钥" />
                                        </Button.ToolTip>
                                        <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                                            <Canvas Width="24"
                                                    Height="24">
                                                <Path Data="M8,8 L18,8 L18,18 L8,18 Z M6,15 L4,15 L4,4 L15,4 L15,6"
                                                      Fill="Transparent"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </Grid>
                                <Button x:Name="FirstRunSaveToDesktopButton"
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource ShellIconButtonStyle}"
                                        Width="34"
                                        Height="34"
                                        Click="FirstRunSaveToDesktopButton_Click"
                                        AutomationProperties.AutomationId="FirstRunSaveToDesktopButton"
                                        AutomationProperties.Name="保存到桌面">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource ShellTextToolTipStyle}"
                                                 Content="保存到桌面" />
                                    </Button.ToolTip>
                                    <Viewbox Style="{StaticResource ShellIconViewboxStyle}">
                                        <Canvas Width="24"
                                                Height="24">
                                            <Path Data="M12,5 L18,11 L12,17 M18,11 L7,11 M7,11 C5.343,11 4,12.343 4,14 L4,17 C4,18.657 5.343,20 7,20 L17,20 C18.657,20 20,18.657 20,17 L20,15"
                                                  Fill="Transparent"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                  StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <CheckBox x:Name="FirstRunRememberSecurityKeyCheckBox"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        IsChecked="False"
                                        AutomationProperties.AutomationId="FirstRunRememberSecurityKeyCheckBox"
                                        Content="本机记住安全密钥" />
                            </Grid>
                            <Button x:Name="FirstRunEnterManagementButton"
                                    Height="38"
                                    Margin="0,24,0,0"
                                    Click="FirstRunEnterManagementButton_Click"
                                    AutomationProperties.AutomationId="FirstRunEnterManagementButton"
                                    Content="进入管理界面" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="FirstRunConfirmPanel"
                      Visibility="Collapsed"
                      Background="#99000000"
                      AutomationProperties.AutomationId="FirstRunConfirmPanel">
                    <Border Width="420"
                            Padding="0"
                            CornerRadius="16"
                            Style="{StaticResource ShellRaisedPanelStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button x:Name="FirstRunConfirmCloseButton"
                                    Grid.Row="0"
                                    Width="46"
                                    Height="34"
                                    Padding="0"
                                    Style="{StaticResource DialogCloseButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="FirstRunConfirmCloseButton_Click"
                                    Content="×"
                                    AutomationProperties.AutomationId="FirstRunConfirmCloseButton"
                                    AutomationProperties.Name="关闭" />
                            <StackPanel Grid.Row="1"
                                        Margin="28,8,28,28">
                                <TextBlock
                                           Text="确认已保存安全密钥"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="关闭本页后，完整安全密钥不会再次显示。未保存密钥且未选择本机记住时，之后需要重置才能重新初始化。"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <Button x:Name="FirstRunConfirmContinueButton"
                                        Width="84"
                                        Height="36"
                                        Margin="0,24,0,0"
                                        HorizontalAlignment="Center"
                                        Click="FirstRunConfirmContinueButton_Click"
                                        AutomationProperties.AutomationId="FirstRunConfirmContinueButton"
                                        Content="确认" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="LoginPanel"
              Grid.Row="1"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              AutomationProperties.AutomationId="LoginPanel">
            <Border Width="440"
                    Padding="28"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="登录 CodexCliPlus"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,10,0,18"
                               Text="请输入安全密钥以进入桌面管理界面。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="安全密钥"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <PasswordBox x:Name="ManagementKeyPasswordBox"
                                 Height="36"
                                 Margin="0,8,0,0"
                                 KeyDown="ManagementKeyPasswordBox_KeyDown" />
                    <CheckBox x:Name="RememberManagementKeyCheckBox"
                              Margin="0,16,0,0"
                              Content="本机记住安全密钥" />
                    <TextBlock x:Name="LoginErrorText"
                               Margin="0,12,0,0"
                               FontSize="13"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                    <Button x:Name="LoginButton"
                            Height="38"
                            Margin="0,22,0,0"
                            Click="LoginButton_Click"
                            AutomationProperties.AutomationId="LoginButton"
                            Content="登录" />
                    <Button x:Name="ForgotSecurityKeyButton"
                            Height="34"
                            Margin="0,12,0,0"
                            Click="ForgotSecurityKeyButton_Click"
                            Content="忘记安全密钥/重置" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="LoadingPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}"
              AutomationProperties.AutomationId="LoadingPanel">
            <Border Width="520"
                    Padding="30"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="56"
                              Height="56"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Border x:Name="LoadingBrandHalo"
                                    Width="56"
                                    Height="56"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    CornerRadius="18"
                                    Opacity="0.38">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever"
                                                        AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.24"
                                                                 To="0.58"
                                                                 Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Border.Effect>
                                    <BlurEffect Radius="5" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="LoadingBrandBadge"
                                    Width="48"
                                    Height="48"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    CornerRadius="14">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever"
                                                        AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.82"
                                                                 To="1"
                                                                 Duration="0:0:0.8" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <Image Width="32"
                                   Height="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png" />
                            <Ellipse Width="7"
                                     Height="7"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,5,5"
                                     Fill="{DynamicResource AccentBrush}"
                                     Stroke="{DynamicResource SurfaceBrush}"
                                     StrokeThickness="1">
                                <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.42"
                                                             To="1"
                                                             Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <StackPanel Margin="14,6,0,0">
                            <TextBlock Text="CodexCliPlus"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock x:Name="LoadingStatusText"
                                       Margin="0,6,0,0"
                                       Text="正在启动桌面宿主"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="LoadingTitleText"
                               Margin="0,18,0,0"
                               Text="正在准备桌面管理界面"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="LoadingDescriptionText"
                               Margin="0,10,0,18"
                               Text="正在准备本地后端和桌面桥接。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <Border x:Name="PreparationProgressTrack"
                            Height="8"
                            CornerRadius="4"
                            ClipToBounds="True"
                            AutomationProperties.AutomationId="PreparationProgressTrack">
                        <Grid ClipToBounds="True">
                            <ProgressBar x:Name="PreparationProgressBar"
                                         Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         AutomationProperties.AutomationId="PreparationProgressBar"
                                         Value="0" />
                            <Border Width="120"
                                    HorizontalAlignment="Left"
                                    Background="#33FFFFFF">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    From="-120,0,0,0"
                                                                    To="520,0,0,0"
                                                                    Duration="0:0:1.7" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="PreparationStepText"
                               Margin="0,14,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="BlockerPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="560"
                    MaxWidth="560"
                    Padding="30"
                    CornerRadius="20"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="BlockerTitleText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="桌面宿主无法启动" />
                    <TextBlock x:Name="BlockerDescriptionText"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="请先修复宿主级故障，再继续使用管理界面。" />
                    <TextBlock x:Name="BlockerDetailText"
                               Margin="0,18,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Button Width="120"
                                Height="36"
                                Click="RetryButton_Click"
                                Content="重试" />
                        <Button Width="120"
                                Height="36"
                                Margin="12,0,0,0"
                                Click="HideToTrayButton_Click"
                                Content="最小化到托盘" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel x:Name="AutoNotificationStack"
                    Grid.Row="1"
                    Width="380"
                    Margin="0,0,0,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="20"
                    AutomationProperties.AutomationId="AutoNotificationStack" />

        <StackPanel x:Name="ManualNotificationStack"
                    Grid.Row="1"
                    Width="360"
                    Margin="0,0,24,24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="21"
                    AutomationProperties.AutomationId="ManualNotificationStack" />

        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Opacity="0"
              Background="#66000000"
              Panel.ZIndex="60"
              MouseLeftButtonDown="SettingsOverlay_MouseLeftButtonDown"
              AutomationProperties.AutomationId="SettingsOverlay">
            <Border x:Name="SettingsDialogCard"
                    Width="760"
                    MaxHeight="760"
                    Padding="0"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    AutomationProperties.AutomationId="SettingsDialog">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.96"
                                    ScaleY="0.96" />
                </Border.RenderTransform>
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0"
                          Background="{DynamicResource SurfaceAltBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="22,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Width="30"
                                   Height="30"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png" />
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="设置"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Text="CodexCliPlus 桌面控制中心"
                                           Margin="0,2,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="SettingsOverlayCloseButton"
                                Grid.Column="1"
                                Width="46"
                                Height="58"
                                Padding="0"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="SettingsOverlayCloseButton_Click"
                                AutomationProperties.AutomationId="SettingsOverlayCloseButton"
                                AutomationProperties.Name="关闭设置"
                                Content="×"
                                ToolTip="关闭" />
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="700"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,8,0"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="应用"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock x:Name="SettingsAppVersionText"
                                                   Margin="0,10,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock x:Name="SettingsBackendVersionText"
                                                   Margin="0,6,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock x:Name="SettingsBuildTimeText"
                                                   Margin="0,6,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="连接"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock x:Name="SettingsConnectionText"
                                                   Margin="0,10,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock x:Name="SettingsBackendAddressText"
                                                   Margin="0,6,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="10"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="主题"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <StackPanel Margin="0,12,0,0"
                                                Orientation="Horizontal">
                                        <Button x:Name="SettingsThemeSystemButton"
                                                Width="112"
                                                Height="34"
                                                Click="SettingsThemeSystemButton_Click"
                                                AutomationProperties.AutomationId="SettingsThemeSystemButton"
                                                Content="跟随系统" />
                                        <Button x:Name="SettingsThemeWhiteButton"
                                                Width="88"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Click="SettingsThemeWhiteButton_Click"
                                                AutomationProperties.AutomationId="SettingsThemeWhiteButton"
                                                Content="纯白" />
                                        <Button x:Name="SettingsThemeDarkButton"
                                                Width="88"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Click="SettingsThemeDarkButton_Click"
                                                AutomationProperties.AutomationId="SettingsThemeDarkButton"
                                                Content="暗色" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="10"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="模型概览"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock x:Name="SettingsModelOverviewText"
                                               Margin="0,10,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="SettingsProviderOverviewText"
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="10"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="快捷链接"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <StackPanel Margin="0,12,0,0"
                                                Orientation="Horizontal">
                                        <Button Width="118"
                                                Height="34"
                                                Click="SettingsOpenMainRepoButton_Click"
                                                Content="主程序仓库" />
                                        <Button Width="118"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Click="SettingsOpenWebUiRepoButton_Click"
                                                Content="前端仓库" />
                                        <Button Width="96"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Click="SettingsOpenDocsButton_Click"
                                                Content="使用教程" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,8,0"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="本地登录信息"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="清理本机保存的登录状态，不会更改后端配置。"
                                                   Margin="0,10,0,12"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <Button x:Name="SettingsClearLoginButton"
                                                Width="128"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                Click="SettingsClearLoginButton_Click"
                                                AutomationProperties.AutomationId="SettingsClearLoginButton"
                                                Content="清理登录" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Padding="16"
                                        CornerRadius="10"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="请求日志"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock x:Name="SettingsRequestLogText"
                                                   Margin="0,10,0,12"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <Button x:Name="SettingsRequestLogButton"
                                                Width="128"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                Click="SettingsRequestLogButton_Click"
                                                AutomationProperties.AutomationId="SettingsRequestLogButton"
                                                Content="切换请求日志" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Button x:Name="SettingsRefreshInfoButton"
                                    Width="120"
                                    Height="34"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    Click="SettingsRefreshInfoButton_Click"
                                    AutomationProperties.AutomationId="SettingsRefreshInfoButton"
                                    Content="刷新信息" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.RowSpan="2"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                         LeftDoubleClick="TrayIcon_LeftDoubleClick"
                         MenuOnRightClick="True"
                         TooltipText="CodexCliPlus 桌面版">
            <tray:NotifyIcon.Menu>
                <ContextMenu x:Name="TrayMenu">
                    <MenuItem Header="打开"
                              Click="TrayOpenMenuItem_Click" />
                    <MenuItem Header="重启后端"
                              Click="TrayRestartBackendMenuItem_Click" />
                    <MenuItem Header="检查更新"
                              Click="TrayCheckUpdatesMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出"
                              Click="TrayExitMenuItem_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
