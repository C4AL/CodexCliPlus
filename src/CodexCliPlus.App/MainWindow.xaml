<ui:FluentWindow x:Class="CodexCliPlus.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 Title="{Binding Title}"
                 Width="1440"
                 Height="920"
                 MinWidth="960"
                 MinHeight="640"
                 FontFamily="{StaticResource TextThemeFontFamily}"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Auto"
                 WindowStartupLocation="CenterScreen"
                 Closing="Window_Closing"
                 Closed="Window_Closed"
                 Loaded="Window_Loaded"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <DropShadowEffect x:Key="ShellRaisedPanelShadow"
                          BlurRadius="16"
                          Direction="270"
                          Color="#10000000"
                          Opacity="1"
                          ShadowDepth="2" />
        <Style x:Key="ShellRaisedPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Effect" Value="{StaticResource ShellRaisedPanelShadow}" />
        </Style>
        <Style x:Key="ShellIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="46" />
                <ColumnDefinition Width="46" />
            </Grid.ColumnDefinitions>

            <Border x:Name="DragRegion"
                    Grid.Column="0"
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    MouseLeftButtonDown="DragRegion_MouseLeftButtonDown" />

            <Button x:Name="MinimizeWindowButton"
                    Grid.Column="1"
                    Width="46"
                    Height="32"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="MinimizeWindowButton_Click"
                    Content="−"
                    ToolTip="最小化" />
            <Button x:Name="CloseWindowButton"
                    Grid.Column="2"
                    Width="46"
                    Height="32"
                    Padding="0"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="CloseWindowButton_Click"
                    Content="×"
                    ToolTip="关闭" />
        </Grid>

        <wv2:WebView2 x:Name="ManagementWebView"
                      Grid.Row="1"
                      Visibility="Collapsed" />

        <Grid x:Name="UpgradeNoticePanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="500"
                    Padding="30"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="CodexCliPlus 已更新"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="UpgradeNoticeVersionText"
                               Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Text="更新不会更改你的安全密钥、后端配置和账号文件。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <Button x:Name="UpgradeContinueButton"
                            Width="120"
                            Height="38"
                            Margin="0,24,0,0"
                            HorizontalAlignment="Left"
                            Click="UpgradeContinueButton_Click"
                            Content="继续" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="FirstRunKeyPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Border Width="620"
                        Padding="30"
                        Style="{StaticResource ShellRaisedPanelStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="首次初始化安全密钥"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Margin="0,10,0,18"
                                       Text="请立即保存下面的安全密钥。完整内容只会在本页显示一次。"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="安全密钥"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FirstRunSecurityKeyTextBox"
                                         Grid.Column="0"
                                         Height="40"
                                         Width="300"
                                         Padding="10,8"
                                         HorizontalAlignment="Left"
                                         FontFamily="Consolas"
                                         FontSize="15"
                                         HorizontalScrollBarVisibility="Hidden"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap"
                                         VerticalContentAlignment="Center"
                                         VerticalScrollBarVisibility="Disabled" />
                                <StackPanel Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Button x:Name="FirstRunSaveToDesktopButton"
                                            Style="{StaticResource ShellIconButtonStyle}"
                                            Width="32"
                                            Height="32"
                                            Click="FirstRunSaveToDesktopButton_Click"
                                            Content="&#xE72D;"
                                            ToolTip="保存到桌面"
                                            AutomationProperties.Name="保存到桌面" />
                                    <Button x:Name="FirstRunCopyKeyButton"
                                            Style="{StaticResource ShellIconButtonStyle}"
                                            Width="32"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            Click="FirstRunCopyKeyButton_Click"
                                            Content="&#xE8C8;"
                                            ToolTip="复制密钥"
                                            AutomationProperties.Name="复制密钥" />
                                </StackPanel>
                                <CheckBox x:Name="FirstRunRememberSecurityKeyCheckBox"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        IsChecked="False"
                                        Content="本机记住安全密钥" />
                            </Grid>
                            <Button x:Name="FirstRunEnterManagementButton"
                                    Height="38"
                                    Margin="0,24,0,0"
                                    Click="FirstRunEnterManagementButton_Click"
                                    Content="进入管理界面" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="FirstRunConfirmPanel"
                      Visibility="Collapsed"
                      Background="#99000000">
                    <Border Width="420"
                            Padding="0"
                            CornerRadius="16"
                            Style="{StaticResource ShellRaisedPanelStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button x:Name="FirstRunConfirmCloseButton"
                                    Grid.Row="0"
                                    Width="46"
                                    Height="34"
                                    Padding="0"
                                    Style="{StaticResource TitleBarButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="FirstRunConfirmCloseButton_Click"
                                    Content="×"
                                    ToolTip="关闭"
                                    AutomationProperties.Name="关闭" />
                            <StackPanel Grid.Row="1"
                                        Margin="28,8,28,28">
                                <TextBlock
                                           Text="确认已保存安全密钥"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="关闭本页后，完整安全密钥不会再次显示。未保存密钥且未选择本机记住时，之后需要重置才能重新初始化。"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <Button x:Name="FirstRunConfirmContinueButton"
                                        Width="84"
                                        Height="36"
                                        Margin="0,24,0,0"
                                        HorizontalAlignment="Center"
                                        Click="FirstRunConfirmContinueButton_Click"
                                        Content="确认" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="LoginPanel"
              Grid.Row="1"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="440"
                    Padding="28"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="登录 CodexCliPlus"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,10,0,18"
                               Text="请输入安全密钥以进入桌面管理界面。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="安全密钥"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <PasswordBox x:Name="ManagementKeyPasswordBox"
                                 Height="36"
                                 Margin="0,8,0,0"
                                 KeyDown="ManagementKeyPasswordBox_KeyDown" />
                    <CheckBox x:Name="RememberManagementKeyCheckBox"
                              Margin="0,16,0,0"
                              Content="本机记住安全密钥" />
                    <TextBlock x:Name="LoginErrorText"
                               Margin="0,12,0,0"
                               FontSize="13"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                    <Button x:Name="LoginButton"
                            Height="38"
                            Margin="0,22,0,0"
                            Click="LoginButton_Click"
                            Content="登录" />
                    <Button x:Name="ForgotSecurityKeyButton"
                            Height="34"
                            Margin="0,12,0,0"
                            Click="ForgotSecurityKeyButton_Click"
                            Content="忘记安全密钥/重置" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="LoadingPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="520"
                    Padding="30"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="LoadingBrandBadge"
                                Width="48"
                                Height="48"
                                Background="{DynamicResource AccentSoftBrush}"
                                CornerRadius="14"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1"
                                                ScaleY="1" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.72"
                                                             To="1"
                                                             Duration="0:0:0.8" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             From="0.96"
                                                             To="1.04"
                                                             Duration="0:0:0.8" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.96"
                                                             To="1.04"
                                                             Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Image Width="30"
                                   Height="30"
                                   Source="pack://application:,,,/Resources/Icons/codexcliplus.ico" />
                        </Border>
                        <StackPanel Margin="14,2,0,0">
                            <TextBlock Text="CodexCliPlus"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock x:Name="LoadingStatusText"
                                       Margin="0,6,0,0"
                                       Text="正在启动桌面宿主"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="LoadingTitleText"
                               Margin="0,18,0,0"
                               Text="正在准备桌面管理界面"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock x:Name="LoadingDescriptionText"
                               Margin="0,10,0,18"
                               Text="正在准备本地后端和桌面桥接。"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <Grid Height="8">
                        <ProgressBar x:Name="PreparationProgressBar"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0" />
                        <Border Width="120"
                                HorizontalAlignment="Left"
                                Background="#33FFFFFF">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                From="-120,0,0,0"
                                                                To="520,0,0,0"
                                                                Duration="0:0:1.7" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="PreparationStepText"
                               Margin="0,14,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="BlockerPanel"
              Grid.Row="1"
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border Width="560"
                    MaxWidth="560"
                    Padding="30"
                    CornerRadius="20"
                    Style="{StaticResource ShellRaisedPanelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="BlockerTitleText"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="桌面宿主无法启动" />
                    <TextBlock x:Name="BlockerDescriptionText"
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="请先修复宿主级故障，再继续使用管理界面。" />
                    <TextBlock x:Name="BlockerDetailText"
                               Margin="0,18,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Button Width="120"
                                Height="36"
                                Click="RetryButton_Click"
                                Content="重试" />
                        <Button Width="120"
                                Height="36"
                                Margin="12,0,0,0"
                                Click="HideToTrayButton_Click"
                                Content="最小化到托盘" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel x:Name="AutoNotificationStack"
                    Grid.Row="1"
                    Width="380"
                    Margin="0,0,0,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="20" />

        <StackPanel x:Name="ManualNotificationStack"
                    Grid.Row="1"
                    Width="360"
                    Margin="0,0,24,24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="21" />

        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.RowSpan="2"
                         FocusOnLeftClick="False"
                         Icon="pack://application:,,,/Resources/Icons/codexcliplus.ico"
                         LeftDoubleClick="TrayIcon_LeftDoubleClick"
                         MenuOnRightClick="True"
                         TooltipText="CodexCliPlus 桌面版">
            <tray:NotifyIcon.Menu>
                <ContextMenu x:Name="TrayMenu">
                    <MenuItem Header="打开"
                              Click="TrayOpenMenuItem_Click" />
                    <MenuItem Header="重启后端"
                              Click="TrayRestartBackendMenuItem_Click" />
                    <MenuItem Header="检查更新"
                              Click="TrayCheckUpdatesMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="退出"
                              Click="TrayExitMenuItem_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
