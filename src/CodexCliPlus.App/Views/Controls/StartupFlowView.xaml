<UserControl
  x:Class="CodexCliPlus.Views.Controls.StartupFlowView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  FontFamily="{StaticResource TextThemeFontFamily}"
>
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Views/Resources/ShellResources.xaml" />
        <ResourceDictionary Source="/Views/Resources/StartupFlowResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid
    x:Name="StartupFlowRoot"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    AutomationProperties.AutomationId="StartupFlowView"
  >
    <Grid
      x:Name="CompactAuthenticationHost"
      Visibility="Collapsed"
      ClipToBounds="True"
      Background="{StaticResource StartupAuthenticationBackgroundBrush}"
      AutomationProperties.AutomationId="CompactAuthenticationHost"
    >
      <Grid.RenderTransform>
        <TranslateTransform x:Name="CompactAuthenticationTranslateTransform" />
      </Grid.RenderTransform>
      <Grid.RowDefinitions>
        <RowDefinition Height="42" />
        <RowDefinition Height="*" />
        <RowDefinition Height="46" />
      </Grid.RowDefinitions>

      <Border
        Grid.RowSpan="3"
        Margin="0,0,0,1"
        Background="{StaticResource StartupAuthenticationLightSweepBrush}"
        IsHitTestVisible="False"
      />

      <Border
        x:Name="AuthenticationDragRegion"
        Grid.Row="0"
        Background="Transparent"
        MouseLeftButtonDown="AuthenticationDragRegion_MouseLeftButtonDown"
      />

      <StackPanel
        Grid.Row="0"
        Margin="0,5,6,0"
        Orientation="Horizontal"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
      >
        <Button
          x:Name="AuthenticationMenuButton"
          Style="{StaticResource StartupAuthenticationChromeButtonStyle}"
          Click="AuthenticationMenuButton_Click"
          AutomationProperties.AutomationId="AuthenticationMenuButton"
          AutomationProperties.Name="更多"
          ToolTip="更多"
        >
          <Button.ContextMenu>
            <ContextMenu>
              <MenuItem
                x:Name="AuthenticationMenuResetItem"
                Header="忘记安全密钥/重置"
                Click="AuthenticationMenuResetItem_Click"
              />
            </ContextMenu>
          </Button.ContextMenu>
          <Viewbox Width="15" Height="15">
            <Canvas Width="24" Height="24">
              <Path
                Data="M5,7 L19,7 M5,12 L19,12 M5,17 L19,17"
                Fill="Transparent"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                StrokeThickness="1.7"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
              />
            </Canvas>
          </Viewbox>
        </Button>
        <Button
          x:Name="AuthenticationCloseButton"
          Margin="2,0,0,0"
          Style="{StaticResource StartupAuthenticationChromeButtonStyle}"
          Click="AuthenticationCloseButton_Click"
          AutomationProperties.AutomationId="AuthenticationCloseButton"
          AutomationProperties.Name="关闭"
          ToolTip="关闭"
        >
          <Viewbox Width="14" Height="14">
            <Canvas Width="24" Height="24">
              <Path
                Data="M7,7 L17,17 M17,7 L7,17"
                Fill="Transparent"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                StrokeThickness="1.8"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
              />
            </Canvas>
          </Viewbox>
        </Button>
      </StackPanel>

      <Grid Grid.Row="1" Margin="26,0,26,0">
        <Grid
          x:Name="FirstRunKeyPanel"
          Visibility="Collapsed"
          AutomationProperties.AutomationId="FirstRunKeyPanel"
        >
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Height="78">
            <Border
              Width="64"
              Height="64"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              CornerRadius="32"
              Background="#F7FFFFFF"
              BorderBrush="#B8FFFFFF"
              BorderThickness="1"
            >
              <Image
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderOptions.BitmapScalingMode="HighQuality"
                SnapsToDevicePixels="True"
                Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png"
              />
            </Border>
          </Grid>

          <TextBlock
            Grid.Row="1"
            Margin="0,12,0,0"
            Style="{StaticResource StartupCompactWindowTitleTextStyle}"
            HorizontalAlignment="Center"
            Text="初始化"
          />

          <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Style="{StaticResource StartupFlowLabelTextStyle}" Text="安全密钥" />
            <Border
              x:Name="FirstRunSecurityKeyDisplay"
              Margin="0,8,0,0"
              Padding="12,0,5,0"
              Focusable="True"
              Style="{StaticResource StartupFlowKeyDisplayStyle}"
              AutomationProperties.AutomationId="FirstRunSecurityKeyDisplay"
              AutomationProperties.Name="安全密钥"
            >
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  x:Name="FirstRunSecurityKeyText"
                  Grid.Column="0"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  FontFamily="Consolas"
                  FontSize="13"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  AutomationProperties.AutomationId="FirstRunSecurityKeyText"
                  TextTrimming="CharacterEllipsis"
                  TextWrapping="NoWrap"
                />
                <StackPanel
                  Grid.Column="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                >
                  <Button
                    x:Name="FirstRunCopyKeyButton"
                    Style="{StaticResource ShellInlineIconButtonStyle}"
                    Width="30"
                    Height="30"
                    Click="FirstRunCopyKeyButton_Click"
                    AutomationProperties.AutomationId="FirstRunCopyKeyButton"
                    AutomationProperties.Name="复制密钥"
                  >
                    <Button.ToolTip>
                      <ToolTip
                        Style="{StaticResource ShellTextToolTipStyle}"
                        AutomationProperties.Name="复制密钥"
                        Content="复制密钥"
                      />
                    </Button.ToolTip>
                    <iconPacks:PackIconLucide
                      Kind="Copy"
                      Width="15"
                      Height="15"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                    />
                  </Button>
                  <Button
                    x:Name="FirstRunSaveToDesktopButton"
                    Margin="3,0,0,0"
                    Style="{StaticResource ShellInlineIconButtonStyle}"
                    Width="30"
                    Height="30"
                    Click="FirstRunSaveToDesktopButton_Click"
                    AutomationProperties.AutomationId="FirstRunSaveToDesktopButton"
                    AutomationProperties.Name="保存到桌面"
                  >
                    <Button.ToolTip>
                      <ToolTip
                        Style="{StaticResource ShellTextToolTipStyle}"
                        AutomationProperties.Name="保存到桌面"
                        Content="保存到桌面"
                      />
                    </Button.ToolTip>
                    <iconPacks:PackIconLucide
                      Kind="Save"
                      Width="15"
                      Height="15"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                    />
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>

          <StackPanel Grid.Row="3" Margin="0,14,0,0" VerticalAlignment="Bottom">
            <Button
              x:Name="FirstRunEnterManagementButton"
              Style="{StaticResource StartupPrimaryButtonStyle}"
              HorizontalAlignment="Stretch"
              Click="FirstRunEnterManagementButton_Click"
              AutomationProperties.AutomationId="FirstRunEnterManagementButton"
              Content="进入管理界面"
            />
          </StackPanel>
        </Grid>

        <Grid
          x:Name="LoginPanel"
          Visibility="Collapsed"
          AutomationProperties.AutomationId="LoginPanel"
        >
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Height="78">
            <Border
              Width="64"
              Height="64"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              CornerRadius="32"
              Background="#F7FFFFFF"
              BorderBrush="#B8FFFFFF"
              BorderThickness="1"
            >
              <Image
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderOptions.BitmapScalingMode="HighQuality"
                SnapsToDevicePixels="True"
                Source="pack://application:,,,/Resources/Icons/codexcliplus-display.png"
              />
            </Border>
          </Grid>

          <TextBlock
            Grid.Row="1"
            Margin="0,12,0,0"
            Style="{StaticResource StartupCompactWindowTitleTextStyle}"
            HorizontalAlignment="Center"
            Text="安全密钥登录"
          />

          <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Style="{StaticResource StartupFlowLabelTextStyle}" Text="安全密钥" />
            <PasswordBox
              x:Name="ManagementKeyPasswordBox"
              Margin="0,8,0,0"
              HorizontalAlignment="Stretch"
              Style="{StaticResource StartupFlowPasswordBoxStyle}"
              KeyDown="ManagementKeyPasswordBox_KeyDown"
              AutomationProperties.AutomationId="ManagementKeyPasswordBox"
              AutomationProperties.Name="安全密钥"
            />
          </StackPanel>

          <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
              <CheckBox
                x:Name="RememberPasswordCheckBox"
                VerticalAlignment="Center"
                Checked="PersistenceOptionCheckBox_Changed"
                Unchecked="PersistenceOptionCheckBox_Changed"
                AutomationProperties.AutomationId="RememberPasswordCheckBox"
                AutomationProperties.Name="记住密码"
              />
              <TextBlock
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                Cursor="Hand"
                Style="{StaticResource StartupOptionTextStyle}"
                MouseLeftButtonDown="PersistenceOptionLabel_MouseLeftButtonDown"
                Tag="{Binding ElementName=RememberPasswordCheckBox}"
                Text="记住密码"
              />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <CheckBox
                x:Name="AutoLoginCheckBox"
                VerticalAlignment="Center"
                Checked="PersistenceOptionCheckBox_Changed"
                Unchecked="PersistenceOptionCheckBox_Changed"
                AutomationProperties.AutomationId="AutoLoginCheckBox"
                AutomationProperties.Name="自动登录"
              />
              <TextBlock
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                Cursor="Hand"
                Style="{StaticResource StartupOptionTextStyle}"
                MouseLeftButtonDown="PersistenceOptionLabel_MouseLeftButtonDown"
                Tag="{Binding ElementName=AutoLoginCheckBox}"
                Text="自动登录"
              />
            </StackPanel>
          </Grid>

          <StackPanel Grid.Row="4" Margin="0,12,0,0" VerticalAlignment="Bottom">
            <TextBlock
              x:Name="LoginErrorText"
              MinHeight="34"
              Margin="0,0,0,10"
              Style="{StaticResource StartupFlowErrorTextStyle}"
              Visibility="Hidden"
            />
            <Button
              x:Name="LoginButton"
              Style="{StaticResource StartupPrimaryButtonStyle}"
              HorizontalAlignment="Stretch"
              Click="LoginButton_Click"
              AutomationProperties.AutomationId="LoginButton"
              Content="登录"
            />
          </StackPanel>
        </Grid>
      </Grid>

      <StackPanel
        Grid.Row="2"
        Orientation="Horizontal"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
      >
        <TextBlock Style="{StaticResource StartupProtocolTextStyle}" Text="已阅读并同意本机" />
        <TextBlock
          Style="{StaticResource StartupProtocolLinkTextStyle}"
          Text="安全密钥规则"
          Cursor="Help"
          AutomationProperties.Name="安全密钥规则"
          ToolTipService.InitialShowDelay="120"
          ToolTipService.BetweenShowDelay="0"
          ToolTipService.ShowDuration="20000"
        >
          <TextBlock.ToolTip>
            <ToolTip
              Style="{StaticResource ShellRiskToolTipStyle}"
              AutomationProperties.Name="安全密钥规则"
            >
              <TextBlock
                MaxWidth="236"
                Text="记住密码会把安全密钥保存在本机凭据存储中；自动登录会在启动时用已保存密钥直接进入管理界面。仅在受信任的个人设备上使用。"
                TextWrapping="Wrap"
                Foreground="#B42318"
              />
            </ToolTip>
          </TextBlock.ToolTip>
        </TextBlock>
      </StackPanel>
    </Grid>

    <Popup
      x:Name="FirstRunConfirmPopup"
      PlacementTarget="{Binding ElementName=FirstRunEnterManagementButton}"
      Placement="Bottom"
      HorizontalOffset="0"
      VerticalOffset="8"
      AllowsTransparency="True"
      StaysOpen="True"
      PopupAnimation="None"
      AutomationProperties.AutomationId="FirstRunConfirmPopup"
    >
      <Border
        x:Name="FirstRunConfirmPanel"
        Width="{Binding ActualWidth, ElementName=FirstRunEnterManagementButton}"
        Padding="10"
        CornerRadius="8"
        Background="#EFFFFFFF"
        BorderBrush="#80B7D7EC"
        BorderThickness="1"
        AutomationProperties.AutomationId="FirstRunConfirmPanel"
      >
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Style="{StaticResource StartupCompactConfirmTitleTextStyle}"
            Text="确认已保存安全密钥"
          />
          <Button
            x:Name="FirstRunConfirmCloseButton"
            Grid.Row="0"
            Grid.Column="1"
            Width="24"
            Height="24"
            Padding="0"
            Style="{StaticResource StartupLinkButtonStyle}"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Click="FirstRunConfirmCloseButton_Click"
            Content="×"
            AutomationProperties.AutomationId="FirstRunConfirmCloseButton"
            AutomationProperties.Name="关闭"
          />
          <TextBlock
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,4,0,0"
            MaxHeight="34"
            Style="{StaticResource StartupCompactHintTextStyle}"
            Text="关闭本页后，完整安全密钥不会再次显示。"
            TextWrapping="Wrap"
            TextTrimming="CharacterEllipsis"
          />
          <Button
            x:Name="FirstRunConfirmContinueButton"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Height="30"
            Margin="0,8,0,0"
            HorizontalAlignment="Stretch"
            Style="{StaticResource StartupSecondaryButtonStyle}"
            Click="FirstRunConfirmContinueButton_Click"
            AutomationProperties.AutomationId="FirstRunConfirmContinueButton"
            Content="确认"
          />
        </Grid>
      </Border>
    </Popup>
  </Grid>
</UserControl>
