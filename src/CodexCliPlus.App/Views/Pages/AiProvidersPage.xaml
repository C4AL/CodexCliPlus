<Page x:Class="CodexCliPlus.Views.Pages.AiProvidersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
      Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="{StaticResource ManagementPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource ManagementPageTitleStyle}"
                   Text="{Binding Title}" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Style="{StaticResource ManagementPageSubtitleStyle}"
                   Text="{Binding Subtitle}" />

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    Orientation="Horizontal">
            <ds:StatusBadge x:Name="StatusBadge" />
            <TextBlock x:Name="ErrorTextBlock"
                       Margin="12,4,0,0"
                       Foreground="{StaticResource ManagementDangerBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="3">
            <ds:FloatingActionBar Margin="0,20,0,0">
                <ds:FloatingActionBar.LeadingContent>
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                   Text="Provider route catalog" />
                        <TextBlock Style="{StaticResource ManagementHintTextStyle}"
                                   Text="Secondary route path and rendered view stay in sync." />
                    </StackPanel>
                </ds:FloatingActionBar.LeadingContent>
                <ds:FloatingActionBar.TrailingContent>
                    <Button Click="RefreshButton_Click"
                            Content="Refresh" />
                </ds:FloatingActionBar.TrailingContent>
            </ds:FloatingActionBar>

            <TextBlock x:Name="RouteTextBlock"
                       Margin="0,10,0,0"
                       Style="{StaticResource ManagementHintTextStyle}" />
        </StackPanel>

        <Grid Grid.Row="4"
              Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ds:ProviderCard x:Name="GeminiCard"
                                     Margin="0,0,0,12"
                                     Click="ProviderCard_Click" />
                    <ds:ProviderCard x:Name="CodexCard"
                                     Margin="0,0,0,12"
                                     Click="ProviderCard_Click" />
                    <ds:ProviderCard x:Name="ClaudeCard"
                                     Margin="0,0,0,12"
                                     Click="ProviderCard_Click" />
                    <ds:ProviderCard x:Name="VertexCard"
                                     Margin="0,0,0,12"
                                     Click="ProviderCard_Click" />
                    <ds:ProviderCard x:Name="OpenAiCard"
                                     Margin="0,0,0,12"
                                     Click="ProviderCard_Click" />
                    <ds:ProviderCard x:Name="AmpcodeCard"
                                     Click="ProviderCard_Click" />
                </StackPanel>
            </ScrollViewer>

            <ds:SecondaryPageShell x:Name="DetailShell"
                                   Grid.Column="2" />
        </Grid>
    </Grid>
</Page>
