<Page x:Class="CodexCliPlus.Views.Pages.AuthFilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
      Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="{StaticResource ManagementPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource ManagementPageTitleStyle}"
                   Text="{Binding Title}" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Style="{StaticResource ManagementPageSubtitleStyle}"
                   Text="{Binding Subtitle}" />

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    Orientation="Horizontal">
            <ds:StatusBadge x:Name="StatusBadge" />
            <TextBlock x:Name="ErrorTextBlock"
                       Margin="12,4,0,0"
                       Foreground="{StaticResource ManagementDangerBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="3">
            <ds:FloatingActionBar Margin="0,20,0,0">
                <ds:FloatingActionBar.LeadingContent>
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                   Text="Auth files and OAuth routes" />
                        <TextBlock Style="{StaticResource ManagementHintTextStyle}"
                                   Text="Batch actions stay in the list context, while details render in the route host." />
                    </StackPanel>
                </ds:FloatingActionBar.LeadingContent>
                <ds:FloatingActionBar.TrailingContent>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="RefreshButton_Click"
                                Content="Refresh" />
                        <Button Background="{StaticResource ManagementAccentBrush}"
                                Foreground="White"
                                Click="UploadButton_Click"
                                Content="Upload JSON" />
                    </StackPanel>
                </ds:FloatingActionBar.TrailingContent>
            </ds:FloatingActionBar>

            <TextBlock x:Name="RouteTextBlock"
                       Margin="0,10,0,0"
                       Style="{StaticResource ManagementHintTextStyle}" />
        </StackPanel>

        <ds:BatchActionBar x:Name="BatchActionBar"
                           Grid.Row="4"
                           Margin="0,18,0,0"
                           Visibility="Collapsed">
            <ds:BatchActionBar.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Click="DeleteSelectedButton_Click"
                            Content="Delete selected" />
                </StackPanel>
            </ds:BatchActionBar.Actions>
        </ds:BatchActionBar>

        <Grid Grid.Row="5"
              Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="AuthFilesListBox"
                     SelectionChanged="AuthFilesListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ds:AuthFileCard Margin="0,0,0,12"
                                         IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                         IsSelected="{Binding IsSelected}"
                                         MetaText="{Binding MetaText}"
                                         StatusText="{Binding StatusText}"
                                         Subtitle="{Binding Subtitle}"
                                         Title="{Binding Title}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ds:SecondaryPageShell x:Name="DetailShell"
                                   Grid.Column="2" />
        </Grid>
    </Grid>
</Page>
