<Page
  x:Class="CodexCliPlus.Views.Pages.ConfigPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
  Background="{DynamicResource ApplicationBackgroundBrush}"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{StaticResource ManagementPagePadding}">
      <TextBlock Style="{StaticResource ManagementPageTitleStyle}" Text="{Binding Title}" />
      <TextBlock
        Margin="0,8,0,0"
        Style="{StaticResource ManagementPageSubtitleStyle}"
        Text="{Binding Subtitle}"
      />

      <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
        <ds:StatusBadge x:Name="StatusBadge" />
        <TextBlock
          x:Name="ErrorTextBlock"
          Margin="12,4,0,0"
          Foreground="{StaticResource ManagementDangerBrush}"
          TextWrapping="Wrap"
          Visibility="Collapsed"
        />
      </StackPanel>

      <ds:FloatingActionBar Margin="0,20,0,0">
        <ds:FloatingActionBar.LeadingContent>
          <StackPanel>
            <TextBlock
              FontSize="15"
              FontWeight="SemiBold"
              Foreground="{StaticResource ManagementPrimaryTextBrush}"
              Text="{Binding State.ChangedFieldSummary}"
            />
            <TextBlock
              Style="{StaticResource ManagementHintTextStyle}"
              Text="字段保存会逐项调用已验证的管理接口；高级 YAML 仅作为兜底入口保留。"
            />
          </StackPanel>
        </ds:FloatingActionBar.LeadingContent>
        <ds:FloatingActionBar.TrailingContent>
          <StackPanel Orientation="Horizontal">
            <Button Click="ReloadButton_Click" Content="重新加载" />
            <Button
              IsEnabled="{Binding State.HasAnyChanges}"
              Click="DiscardButton_Click"
              Content="放弃修改"
            />
            <Button
              IsEnabled="{Binding State.CanSaveFields}"
              Background="{StaticResource ManagementAccentBrush}"
              Foreground="White"
              Click="SaveButton_Click"
              Content="保存配置"
            />
          </StackPanel>
        </ds:FloatingActionBar.TrailingContent>
      </ds:FloatingActionBar>

      <ds:ManagementFormSection
        Title="运行时"
        Description="这些设置会直接影响调试、代理和 WebSocket 鉴权行为。"
      >
        <ds:ManagementFormSection.SectionContent>
          <StackPanel>
            <ds:ManagementFieldRow Label="调试模式" Hint="启用后会输出更详细的运行时信息。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox IsChecked="{Binding State.Debug, Mode=TwoWay}" Content="启用调试模式" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="代理地址"
              Hint="留空时会删除 `proxy-url` 设置，不会向后端写入空字符串。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.ProxyUrl, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="WebSocket 鉴权"
              Hint="控制管理端与后端之间的 WebSocket 鉴权。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.WebSocketAuth, Mode=TwoWay}"
                  Content="启用 WebSocket 鉴权"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>
          </StackPanel>
        </ds:ManagementFormSection.SectionContent>
      </ds:ManagementFormSection>

      <ds:ManagementFormSection
        Title="重试与路由"
        Description="重试次数、退避间隔和路由策略会按字段逐项保存。"
      >
        <ds:ManagementFormSection.SectionContent>
          <StackPanel>
            <ds:ManagementFieldRow Label="请求重试次数" Hint="可留空以删除该设置。">
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.RequestRetry, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="最大重试间隔"
              Hint="单位与后端配置保持一致；可留空以删除该设置。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.MaxRetryInterval, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow Label="强制模型前缀" Hint="控制请求转发时是否强制附加模型前缀。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.ForceModelPrefix, Mode=TwoWay}"
                  Content="启用模型前缀强制策略"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="路由策略"
              Hint="常见值如 `fill-first`；留空时会删除 `routing/strategy` 设置。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.RoutingStrategy, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>
          </StackPanel>
        </ds:ManagementFormSection.SectionContent>
      </ds:ManagementFormSection>

      <ds:ManagementFormSection
        Title="日志与统计"
        Description="请求日志、文件日志和统计开关都走单项管理接口保存。"
      >
        <ds:ManagementFormSection.SectionContent>
          <StackPanel>
            <ds:ManagementFieldRow Label="请求日志" Hint="控制是否记录请求级别日志。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.RequestLog, Mode=TwoWay}"
                  Content="启用请求日志"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow Label="写入文件日志" Hint="控制日志是否落盘到文件。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.LoggingToFile, Mode=TwoWay}"
                  Content="启用文件日志"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow Label="用量统计" Hint="控制桌面端和后端的用量统计行为。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.UsageStatisticsEnabled, Mode=TwoWay}"
                  Content="启用用量统计"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow Label="日志总大小上限" Hint="单位为 MB；可留空以删除该设置。">
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.LogsMaxTotalSizeMb, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="错误日志文件上限"
              Hint="控制保留的错误日志文件数量；可留空以删除该设置。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <TextBox Text="{Binding State.ErrorLogsMaxFiles, UpdateSourceTrigger=PropertyChanged}" />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>
          </StackPanel>
        </ds:ManagementFormSection.SectionContent>
      </ds:ManagementFormSection>

      <ds:ManagementFormSection
        Title="配额行为"
        Description="配额耗尽后的回退策略只开放已验证的写回路径。"
      >
        <ds:ManagementFormSection.SectionContent>
          <StackPanel>
            <ds:ManagementFieldRow Label="切换项目" Hint="配额耗尽后自动切换项目。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.SwitchProject, Mode=TwoWay}"
                  Content="启用项目切换"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow Label="切换预览模型" Hint="配额耗尽后自动切换到预览模型。">
              <ds:ManagementFieldRow.FieldContent>
                <CheckBox
                  IsChecked="{Binding State.SwitchPreviewModel, Mode=TwoWay}"
                  Content="启用预览模型切换"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>

            <ds:ManagementFieldRow
              Label="反重力额度"
              Hint="当前版本仅做只读展示，仓库内暂无已验证的写回路径。"
            >
              <ds:ManagementFieldRow.FieldContent>
                <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{StaticResource ManagementPrimaryTextBrush}"
                  Text="{Binding State.AntigravityCreditsDisplay}"
                />
              </ds:ManagementFieldRow.FieldContent>
            </ds:ManagementFieldRow>
          </StackPanel>
        </ds:ManagementFormSection.SectionContent>
      </ds:ManagementFormSection>

      <Expander x:Name="AdvancedYamlExpander" Margin="0,4,0,0" Header="高级 YAML">
        <Border Margin="0,12,0,0" Style="{StaticResource ManagementCardBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource ManagementSectionTitleStyle}" Text="高级 YAML" />
            <TextBlock
              Margin="0,8,0,0"
              Style="{StaticResource ManagementHintTextStyle}"
              Text="{Binding State.AdvancedYamlNotice}"
            />

            <ds:FilterToolbar
              Margin="0,16,0,0"
              SearchText="{Binding State.YamlSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            >
              <ds:FilterToolbar.LeadingContent>
                <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{StaticResource ManagementSecondaryTextBrush}"
                  Text="YAML 搜索"
                />
              </ds:FilterToolbar.LeadingContent>
            </ds:FilterToolbar>

            <TextBlock
              Margin="0,12,0,0"
              Style="{StaticResource ManagementHintTextStyle}"
              Text="{Binding State.YamlSearchResultText}"
            />

            <ds:ManagementCodeEditor
              x:Name="YamlEditor"
              Height="380"
              Margin="0,16,0,0"
              Text="{Binding State.AdvancedYamlDraft, UpdateSourceTrigger=PropertyChanged}"
            />

            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
              <Button Click="ReloadAdvancedYamlButton_Click" Content="重置 YAML 草稿" />
              <Button
                IsEnabled="{Binding State.CanSaveYaml}"
                Background="{StaticResource ManagementAccentBrush}"
                Foreground="White"
                Click="ApplyAdvancedYamlButton_Click"
                Content="应用高级 YAML"
              />
            </StackPanel>
          </StackPanel>
        </Border>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
