<Page x:Class="CodexCliPlus.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
      Background="{DynamicResource ApplicationBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource ManagementPagePadding}">
            <TextBlock Style="{StaticResource ManagementPageTitleStyle}"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource ManagementPageSubtitleStyle}"
                       Text="{Binding Subtitle}" />

            <StackPanel Margin="0,18,0,0"
                        Orientation="Horizontal">
                <ds:StatusBadge x:Name="StatusBadge" />
                <TextBlock x:Name="ErrorTextBlock"
                           Margin="12,4,0,0"
                           Foreground="{StaticResource ManagementDangerBrush}"
                           Visibility="Collapsed" />
            </StackPanel>

            <ItemsControl x:Name="MetricItems"
                          Margin="0,20,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ManagementCardBorderStyle}"
                                Width="250"
                                Margin="0,0,16,16">
                            <StackPanel>
                                <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                           Text="{Binding Value}" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ManagementSecondaryTextBrush}"
                                           Text="{Binding Label}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource ManagementHintTextStyle}"
                                           Text="{Binding Detail}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource ManagementCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                                   Text="连接与版本" />
                        <ItemsControl x:Name="ConnectionItems"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{StaticResource ManagementSecondaryTextBrush}"
                                                   Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                                   Text="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource ManagementCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ManagementSectionTitleStyle}"
                                   Text="提供商摘要" />
                        <ItemsControl x:Name="ProviderItems"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{StaticResource ManagementSecondaryTextBrush}"
                                                   Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource ManagementPrimaryTextBrush}"
                                                   Text="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
