<Page
  x:Class="CodexCliPlus.Views.Pages.LogsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
  Background="{DynamicResource ApplicationBackgroundBrush}"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{StaticResource ManagementPagePadding}">
      <TextBlock Style="{StaticResource ManagementPageTitleStyle}" Text="{Binding Title}" />
      <TextBlock
        Margin="0,8,0,0"
        Style="{StaticResource ManagementPageSubtitleStyle}"
        Text="{Binding Subtitle}"
      />

      <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
        <ds:StatusBadge x:Name="StatusBadge" />
        <TextBlock
          x:Name="ErrorTextBlock"
          Margin="12,4,0,0"
          Foreground="{StaticResource ManagementDangerBrush}"
          TextWrapping="Wrap"
          Visibility="Collapsed"
        />
      </StackPanel>

      <ds:FloatingActionBar Margin="0,20,0,0">
        <ds:FloatingActionBar.LeadingContent>
          <StackPanel>
            <TextBlock
              FontSize="15"
              FontWeight="SemiBold"
              Foreground="{StaticResource ManagementPrimaryTextBrush}"
              Text="日志流检查"
            />
            <TextBlock
              Style="{StaticResource ManagementHintTextStyle}"
              Text="支持增量刷新、全量刷新和清空后即时回读。"
            />
          </StackPanel>
        </ds:FloatingActionBar.LeadingContent>
        <ds:FloatingActionBar.TrailingContent>
          <StackPanel Orientation="Horizontal">
            <Button Click="RefreshIncrementalButton_Click" Content="增量刷新" />
            <Button Click="RefreshFullButton_Click" Content="全量刷新" />
            <Button
              Background="{StaticResource ManagementAccentBrush}"
              Foreground="White"
              Click="ClearButton_Click"
              Content="清空日志"
            />
          </StackPanel>
        </ds:FloatingActionBar.TrailingContent>
      </ds:FloatingActionBar>

      <Border Style="{StaticResource ManagementCardBorderStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource ManagementSectionTitleStyle}" Text="日志流" />
          <TextBlock
            Margin="0,8,0,0"
            Style="{StaticResource ManagementHintTextStyle}"
            Text="显示管理端日志流、总行数和最新时间戳；日志内容在本页内局部滚动。"
          />

          <WrapPanel Margin="0,16,0,16">
            <Border
              Margin="0,0,12,12"
              Padding="12"
              Background="{StaticResource ManagementSurfaceSubtleBrush}"
              BorderBrush="{StaticResource ManagementBorderBrush}"
              BorderThickness="1"
              CornerRadius="12"
            >
              <StackPanel MinWidth="120">
                <TextBlock Style="{StaticResource ManagementHintTextStyle}" Text="当前显示" />
                <TextBlock
                  x:Name="VisibleLineCountText"
                  FontSize="22"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource ManagementPrimaryTextBrush}"
                />
              </StackPanel>
            </Border>

            <Border
              Margin="0,0,12,12"
              Padding="12"
              Background="{StaticResource ManagementSurfaceSubtleBrush}"
              BorderBrush="{StaticResource ManagementBorderBrush}"
              BorderThickness="1"
              CornerRadius="12"
            >
              <StackPanel MinWidth="120">
                <TextBlock Style="{StaticResource ManagementHintTextStyle}" Text="总行数" />
                <TextBlock
                  x:Name="TotalLineCountText"
                  FontSize="22"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource ManagementPrimaryTextBrush}"
                />
              </StackPanel>
            </Border>

            <Border
              Margin="0,0,12,12"
              Padding="12"
              Background="{StaticResource ManagementSurfaceSubtleBrush}"
              BorderBrush="{StaticResource ManagementBorderBrush}"
              BorderThickness="1"
              CornerRadius="12"
            >
              <StackPanel MinWidth="180">
                <TextBlock Style="{StaticResource ManagementHintTextStyle}" Text="最新时间戳" />
                <TextBlock
                  x:Name="LatestTimestampText"
                  FontSize="16"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource ManagementPrimaryTextBrush}"
                />
              </StackPanel>
            </Border>

            <Border
              Margin="0,0,12,12"
              Padding="12"
              Background="{StaticResource ManagementSurfaceSubtleBrush}"
              BorderBrush="{StaticResource ManagementBorderBrush}"
              BorderThickness="1"
              CornerRadius="12"
            >
              <StackPanel MinWidth="120">
                <TextBlock Style="{StaticResource ManagementHintTextStyle}" Text="刷新模式" />
                <TextBlock
                  x:Name="FeedModeText"
                  FontSize="16"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource ManagementPrimaryTextBrush}"
                />
              </StackPanel>
            </Border>
          </WrapPanel>

          <ds:ManagementLogViewer
            x:Name="LogFeedViewer"
            Height="360"
            EmptyTitle="暂无日志内容"
            EmptyDescription="可以尝试全量刷新，或等待后端写入新的日志行。"
          />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource ManagementCardBorderStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource ManagementSectionTitleStyle}" Text="错误日志清单" />
          <TextBlock
            Margin="0,8,0,0"
            Style="{StaticResource ManagementHintTextStyle}"
            Text="展示请求错误日志文件的元信息，便于快速定位文件规模和最后修改时间。"
          />

          <Grid Margin="0,16,0,0">
            <ds:ManagementEmptyState
              x:Name="ErrorLogsEmptyState"
              Title="暂无错误日志文件"
              Description="请求错误日志清单为空，说明当前没有已落盘的错误日志。"
            />

            <ItemsControl x:Name="ErrorLogItems" Visibility="Collapsed">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                    Margin="0,0,0,10"
                    Padding="12"
                    Background="{StaticResource ManagementSurfaceSubtleBrush}"
                    BorderBrush="{StaticResource ManagementBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                  >
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="220" />
                      </Grid.ColumnDefinitions>
                      <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ManagementPrimaryTextBrush}"
                        Text="{Binding Name}"
                      />
                      <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ManagementSecondaryTextBrush}"
                        Text="{Binding Size}"
                      />
                      <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ManagementSecondaryTextBrush}"
                        Text="{Binding Modified}"
                      />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource ManagementCardBorderStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource ManagementSectionTitleStyle}" Text="请求编号检查" />
          <TextBlock
            Margin="0,8,0,0"
            Style="{StaticResource ManagementHintTextStyle}"
            Text="输入请求编号后在当前页面内加载详情；不存在时只显示页内空状态，不再弹出新窗口。"
          />

          <Grid Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
              Margin="0,0,12,0"
              Text="{Binding State.RequestId, UpdateSourceTrigger=PropertyChanged}"
            />
            <Button
              x:Name="LoadRequestLogButton"
              Grid.Column="1"
              Background="{StaticResource ManagementAccentBrush}"
              Foreground="White"
              Click="LoadRequestLogButton_Click"
              Content="加载请求日志"
            />
          </Grid>

          <TextBlock
            x:Name="RequestLogSummaryText"
            Margin="0,0,0,12"
            Style="{StaticResource ManagementHintTextStyle}"
          />

          <ds:ManagementLogViewer
            x:Name="RequestLogViewer"
            Height="280"
            Text="{Binding State.RequestLogContent}"
            EmptyTitle="{Binding State.RequestLogEmptyTitle}"
            EmptyDescription="{Binding State.RequestLogEmptyDescription}"
          />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
