<Page
  x:Class="CodexCliPlus.Views.Pages.QuotaPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ds="clr-namespace:CodexCliPlus.Management.DesignSystem.Controls;assembly=CodexCliPlus.Management.DesignSystem"
  Background="{DynamicResource ApplicationBackgroundBrush}"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{StaticResource ManagementPagePadding}">
      <TextBlock Style="{StaticResource ManagementPageTitleStyle}" Text="{Binding Title}" />
      <TextBlock
        Margin="0,8,0,0"
        Style="{StaticResource ManagementPageSubtitleStyle}"
        Text="{Binding Subtitle}"
      />

      <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
        <ds:StatusBadge x:Name="StatusBadge" />
        <TextBlock
          x:Name="ErrorTextBlock"
          Margin="12,4,0,0"
          Foreground="{StaticResource ManagementDangerBrush}"
          Visibility="Collapsed"
        />
      </StackPanel>

      <Border Style="{StaticResource ManagementCardBorderStyle}" Margin="0,20,0,0">
        <StackPanel>
          <TextBlock Style="{StaticResource ManagementSectionTitleStyle}" Text="配额回退配置" />
          <ItemsControl x:Name="QuotaItems" Margin="0,16,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Foreground="{StaticResource ManagementSecondaryTextBrush}"
                    Text="{Binding Label}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Foreground="{StaticResource ManagementPrimaryTextBrush}"
                    Text="{Binding Value}"
                  />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
            <Button Click="ToggleSwitchProjectButton_Click" Content="切换项目开关" />
            <Button Click="ToggleSwitchPreviewModelButton_Click" Content="切换预览模型开关" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
