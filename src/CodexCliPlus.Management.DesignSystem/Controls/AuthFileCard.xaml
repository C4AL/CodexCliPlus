<UserControl x:Class="CodexCliPlus.Management.DesignSystem.Controls.AuthFileCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border x:Name="CardBorder"
            Padding="16"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <CheckBox IsChecked="{Binding IsChecked, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center" />
                <TextBlock Margin="10,0,0,0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ManagementPrimaryTextBrush}"
                           Text="{Binding Title, ElementName=Root}" />
                <TextBlock DockPanel.Dock="Right"
                           Foreground="{StaticResource ManagementSecondaryTextBrush}"
                           Text="{Binding StatusText, ElementName=Root}" />
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Style="{StaticResource ManagementHintTextStyle}"
                       Text="{Binding Subtitle, ElementName=Root}" />

            <TextBlock Grid.Row="2"
                       Margin="0,10,0,0"
                       FontSize="12"
                       Foreground="{StaticResource ManagementAccentStrongBrush}"
                       Text="{Binding MetaText, ElementName=Root}" />
        </Grid>
    </Border>
</UserControl>
