<UserControl x:Class="CodexCliPlus.Management.DesignSystem.Controls.EditableModelAliasList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ManagementSecondaryTextBrush}"
                       Text="名称" />
            <TextBlock Grid.Column="1"
                       Margin="8,0,0,0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ManagementSecondaryTextBrush}"
                       Text="别名" />
            <TextBlock Grid.Column="2"
                       Margin="8,0,0,0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ManagementSecondaryTextBrush}"
                       Text="优先级"
                       Visibility="{Binding ShowPriority, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Grid.Column="3"
                       Margin="8,0,0,0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ManagementSecondaryTextBrush}"
                       Text="测试模型"
                       Visibility="{Binding ShowTestModel, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Grid.Column="4"
                       Margin="8,0,0,0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ManagementSecondaryTextBrush}"
                       Text="Fork"
                       Visibility="{Binding ShowFork, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="1"
                                 Margin="8,0,0,0"
                                 Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Column="2"
                                 Margin="8,0,0,0"
                                 Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding ShowPriority, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBox Grid.Column="3"
                                 Margin="8,0,0,0"
                                 Text="{Binding TestModel, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding ShowTestModel, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <CheckBox Grid.Column="4"
                                  Margin="16,0,0,0"
                                  HorizontalAlignment="Center"
                                  IsChecked="{Binding Fork, UpdateSourceTrigger=PropertyChanged}"
                                  Visibility="{Binding ShowFork, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Grid.Column="5"
                                Margin="8,0,0,0"
                                Click="RemoveButton_Click"
                                Content="删除"
                                Tag="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Margin="0,4,0,0"
                HorizontalAlignment="Left"
                Click="AddButton_Click"
                Content="{Binding AddButtonText, ElementName=Root}" />
    </StackPanel>
</UserControl>
