<UserControl
  x:Class="CodexCliPlus.Management.DesignSystem.Controls.FilterToolbar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Name="Root"
>
  <Border Style="{StaticResource ManagementCardBorderStyle}">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <ContentPresenter
        Content="{Binding LeadingContent, ElementName=Root}"
        Margin="0,0,12,0"
        VerticalAlignment="Center"
      />
      <TextBox
        Grid.Column="1"
        x:Name="SearchBox"
        VerticalAlignment="Center"
        TextChanged="SearchBox_TextChanged"
        Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
      />
      <ContentPresenter
        Grid.Column="2"
        Margin="12,0,0,0"
        Content="{Binding TrailingContent, ElementName=Root}"
        VerticalAlignment="Center"
      />
    </Grid>
  </Border>
</UserControl>
