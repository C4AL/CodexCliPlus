<UserControl x:Class="CodexCliPlus.Management.DesignSystem.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border x:Name="BadgeBorder"
            Padding="10,4"
            CornerRadius="{StaticResource ManagementBadgeCornerRadius}">
        <TextBlock x:Name="BadgeTextBlock"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Text="{Binding Text, ElementName=Root}" />
    </Border>
</UserControl>
