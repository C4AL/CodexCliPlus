<controlzEx:WindowChromeWindow
  x:Class="CodexCliPlus.Updater.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controlzEx="urn:controlzex"
  Title="CodexCliPlus 更新"
  Width="520"
  Height="260"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterScreen"
  ResizeBorderThickness="0"
  CornerPreference="Round"
  UseNativeCaptionButtons="True"
  ShowMinButton="False"
  ShowMaxRestoreButton="False"
  GlassFrameThickness="1"
  GlowColor="#330F766E"
  NonActiveGlowColor="#180F172A"
  GlowDepth="8"
  PreferDWMBorderColor="True"
  UseRadialGradientForCorners="True"
  Loaded="Window_Loaded"
>
  <Grid Background="#F6F8FB">
    <Border
      Margin="24"
      Padding="22"
      CornerRadius="12"
      Background="White"
      BorderBrush="#D7DCE5"
      BorderThickness="1"
    >
      <StackPanel>
        <TextBlock
          Text="正在更新 CodexCliPlus"
          FontSize="22"
          FontWeight="SemiBold"
          Foreground="#17202B"
        />
        <TextBlock
          x:Name="StatusText"
          Margin="0,12,0,0"
          Text="正在准备更新。"
          FontSize="14"
          Foreground="#526070"
          TextWrapping="Wrap"
        />
        <ProgressBar
          x:Name="Progress"
          Margin="0,22,0,0"
          Height="6"
          Minimum="0"
          Maximum="100"
          IsIndeterminate="True"
        />
        <Button
          x:Name="CloseButton"
          Width="96"
          Height="34"
          Margin="0,24,0,0"
          HorizontalAlignment="Right"
          Click="CloseButton_Click"
          Content="关闭"
          IsEnabled="False"
        />
      </StackPanel>
    </Border>
  </Grid>
</controlzEx:WindowChromeWindow>
