<Application x:Class="DesktopHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F7F4EE" />
        <SolidColorBrush x:Key="AppCardBrush" Color="#FFFDFC" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#D8CCBB" />
        <SolidColorBrush x:Key="AppPrimaryBrush" Color="#184E77" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#C55A11" />
        <SolidColorBrush x:Key="AppMutedBrush" Color="#6E6255" />
    </Application.Resources>
</Application>
