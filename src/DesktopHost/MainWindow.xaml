<Window x:Class="DesktopHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1480"
        Height="920"
        MinWidth="1240"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppWindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border
            Padding="20"
            Background="{DynamicResource AppCardBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="32"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppPrimaryBrush}"
                        Text="{Binding HeaderTitle}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="14"
                        Foreground="{DynamicResource AppMutedBrush}"
                        Text="{Binding HeaderSubtitle}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Border Margin="0,0,10,0" Padding="14,8" Background="#E7F0F7" CornerRadius="999">
                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryBrush}" Text="{Binding BackendBadgeText}" />
                    </Border>
                    <Border Margin="0,0,10,0" Padding="14,8" Background="#FFF1E6" CornerRadius="999">
                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppAccentBrush}" Text="{Binding CurrentSourceText}" />
                    </Border>
                    <Border Padding="14,8" Background="#EEF7E7" CornerRadius="999">
                        <TextBlock FontWeight="SemiBold" Foreground="#2F6B28" Text="{Binding CodexBadgeText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,18,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="16"
                    Background="{DynamicResource AppCardBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <DockPanel LastChildFill="False">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppPrimaryBrush}"
                            Text="管理页宿主" />

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="8,0,0,0" Padding="14,8" Click="RefreshWebViewButton_Click">刷新</Button>
                            <Button Margin="8,0,0,0" Padding="14,8" Click="OpenExternalBrowserButton_Click">外部浏览器打开</Button>
                            <Button Margin="8,0,0,0" Padding="14,8" Click="ClearWebViewCacheButton_Click">清缓存</Button>
                            <Button x:Name="OpenDevToolsButton"
                                    Margin="8,0,0,0"
                                    Padding="14,8"
                                    Visibility="Collapsed"
                                    Click="OpenDevToolsButton_Click">开发工具</Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Background="{DynamicResource AppCardBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid>
                        <wv2:WebView2 x:Name="ManagementWebView" Visibility="Collapsed" />

                        <Grid x:Name="WebViewOverlay">
                            <Border
                                Margin="28"
                                Padding="24"
                                Background="#F3ECE1"
                                CornerRadius="16">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppAccentBrush}"
                                        Text="管理页尚未就绪" />
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontSize="14"
                                        Foreground="{DynamicResource AppMutedBrush}"
                                        Text="{Binding WebViewStatusText}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Width="120"
                                        Margin="0,18,0,0"
                                        Padding="12,8"
                                        HorizontalAlignment="Left"
                                        Click="RetryWebViewButton_Click">重试</Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border
                        Margin="0,0,0,16"
                        Padding="18"
                        Background="{DynamicResource AppCardBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryBrush}" Text="后端托管" />
                            <TextBlock Margin="0,10,0,0" FontSize="14" Text="{Binding BackendStatusText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="{DynamicResource AppMutedBrush}" Text="{Binding BackendDetailText}" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Margin="0,0,8,8" Padding="14,8" Click="StartBackendButton_Click">启动</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="StopBackendButton_Click">停止</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="RestartBackendButton_Click">重启</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="OpenLogsButton_Click">日志目录</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="OpenConfigButton_Click">配置目录</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="OpenBackendButton_Click">后端目录</Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,0,0,16"
                        Padding="18"
                        Background="{DynamicResource AppCardBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryBrush}" Text="Codex CLI" />
                            <TextBlock Margin="0,10,0,0" FontSize="14" Text="{Binding CodexSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="{DynamicResource AppMutedBrush}" Text="{Binding CodexDetailText}" TextWrapping="Wrap" />
                            <Button Width="120" Margin="0,14,0,0" Padding="14,8" HorizontalAlignment="Left" Click="DetectCodexButton_Click">检测 Codex</Button>

                            <TextBlock Margin="0,16,0,0" FontSize="14" FontWeight="SemiBold" Text="当前仓库路径" />
                            <DockPanel Margin="0,10,0,0">
                                <Button DockPanel.Dock="Right" Margin="10,0,0,0" Padding="14,8" Click="BrowseRepositoryButton_Click">选择目录</Button>
                                <TextBox x:Name="RepositoryPathTextBox"
                                         Padding="10,8"
                                         Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="RepositoryPathTextBox_LostFocus" />
                            </DockPanel>

                            <TextBlock Margin="0,16,0,0" FontSize="14" FontWeight="SemiBold" Text="源切换" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Margin="0,0,8,8" Padding="14,8" Click="SetOfficialDefaultButton_Click">设为 official</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="SetCpaDefaultButton_Click">设为 cpa</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="RestoreOfficialButton_Click">恢复官方默认</Button>
                            </WrapPanel>

                            <TextBlock Margin="0,12,0,0" FontSize="14" FontWeight="SemiBold" Text="命令预览" />
                            <TextBox Margin="0,10,0,0"
                                     Padding="10,8"
                                     IsReadOnly="True"
                                     Text="{Binding CommandPreviewText}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Margin="0,0,8,8" Padding="14,8" Click="CopyCommandButton_Click">复制命令</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="LaunchCurrentButton_Click">用当前源启动</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="LaunchOfficialButton_Click">以 official 启动</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="LaunchCpaButton_Click">以 cpa 启动</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="OpenRepoTerminalButton_Click">打开仓库终端</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="OpenCodexConfigButton_Click">Codex 配置目录</Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="18"
                        Background="{DynamicResource AppCardBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryBrush}" Text="诊断与桌面设置" />
                            <TextBlock Margin="0,10,0,0" FontSize="13" Foreground="{DynamicResource AppMutedBrush}" Text="{Binding DiagnosticsSummaryText}" TextWrapping="Wrap" />
                            <CheckBox Margin="0,14,0,0"
                                      Content="开机自启"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                                      Click="StartupCheckBox_Click" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Margin="0,0,8,8" Padding="14,8" Click="CopyDiagnosticsButton_Click">复制诊断信息</Button>
                                <Button Margin="0,0,8,8" Padding="14,8" Click="ResetDesktopConfigButton_Click">重置桌面配置</Button>
                            </WrapPanel>

                            <TextBlock Margin="0,18,0,0" FontSize="14" FontWeight="SemiBold" Text="路径与版本" />
                            <TextBlock Margin="0,10,0,0" FontFamily="Consolas" FontSize="12" Text="{Binding AppDataPath}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" FontFamily="Consolas" FontSize="12" Text="{Binding LogsPath}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0" FontSize="12" Text="{Binding VersionText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" FontSize="12" Text="{Binding InformationalVersionText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{DynamicResource AppCardBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryBrush}" Text="后端与桌面日志" />
                <TextBox Grid.Row="1"
                         Margin="0,14,0,14"
                         Padding="12"
                         IsReadOnly="True"
                         Text="{Binding BackendLogText}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="12" />
                <TextBlock Grid.Row="2"
                           Foreground="{DynamicResource AppMutedBrush}"
                           Text="{Binding FooterStatus}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
